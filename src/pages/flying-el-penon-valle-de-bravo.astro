  .post-hero__content { position: relative; z-index: 2; text-align: center; padding: 2rem 1.5rem 2.5rem; max-width: 800px; }
  .post-hero__content h1 { color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem); text-shadow: 0 2px 8px rgba(0,0,0,0.3); line-height: 1.25; }
  .author-card { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.25rem; background: var(--color-bg-warm, #f9f7f3); border-left: 4px solid var(--color-accent, #e07730); border-radius: 8px; margin: 1.5rem 0; }
  .author-card__avatar { width: 56px; height: 56px; border-radius: 50%; object-fit: cover; border: 2px solid var(--color-accent, #e07730); flex-shrink: 0; }
  .author-card__info { display: flex; flex-direction: column; gap: 0.15rem; }
  .author-card__name { font-size: 1rem; font-weight: 500; color: var(--color-text, #2a2050); text-decoration: none; }
  .author-card__name:hover { color: var(--color-accent, #e07730); }
  .author-card__title { font-size: 0.8rem; font-weight: 500; color: var(--color-accent, #e07730); text-transform: uppercase; letter-spacing: 0.06em; }
  .article-body { max-width: 780px; margin: 0 auto; }
  .article-lead { font-size: 1.15rem; line-height: 1.8; font-weight: 500; margin-bottom: 1.5rem; color: var(--color-text, #2a2050); }
  .article-body h2 { margin-top: 3rem; margin-bottom: 1rem; padding-top: 1rem; border-top: 1px solid var(--color-border, #d8d4e0); }
  .article-body h2:first-of-type { border-top: none; padding-top: 0; }
  .article-body p { font-size: 1.05rem; line-height: 1.8; margin-bottom: 1.25rem; }
  .article-body ul { margin: 1rem 0 1.5rem 1.5rem; list-style: disc; }
