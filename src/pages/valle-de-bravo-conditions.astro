        <a class="reference-link" href="/why-fly-internationally-paragliding/">Why fly internationally</a>
      </div>

      <div class="planning-cta">
        <h2>Ready to pick your dates?</h2>
        <p><a href="/tours/10-day-paraglide-mexico-package/">Book the 10 Day Mexico Package</a> or <a href="/tours/custom-paragliding-trip-mexico/">build a custom trip</a>.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const widget = document.querySelector('[data-weather-widget]');
    const statusEl = document.querySelector('[data-weather-status]');
    const currentEl = document.querySelector('[data-current-weather]');
    const planningEl = document.querySelector('[data-planning-card]');
    const meteogramEl = document.querySelector('[data-meteogram]');
    const hourlyEl = document.querySelector('[data-hourly-strip]');
    const forecastEl = document.querySelector('[data-forecast-strip]');
    const unitButtons = document.querySelectorAll('[data-unit-system]');

    const weatherUrl = 'https://api.open-meteo.com/v1/forecast?latitude=19.1838&longitude=-100.1278&current=temperature_2m,apparent_temperature,relative_humidity_2m,precipitation,weather_code,cloud_cover,surface_pressure,wind_speed_10m,wind_direction_10m,wind_gusts_10m&hourly=temperature_2m,apparent_temperature,relative_humidity_2m,precipitation_probability,precipitation,showers,cloud_cover,wind_speed_10m,wind_direction_10m,wind_gusts_10m,uv_index,visibility&daily=weather_code,temperature_2m_max,temperature_2m_min,apparent_temperature_max,wind_speed_10m_max,wind_gusts_10m_max,wind_direction_10m_dominant,cloud_cover_mean,precipitation_probability_max,uv_index_max,sunrise,sunset&timezone=auto&forecast_days=7&wind_speed_unit=kmh';

    let weatherData = null;
    let unitSystem = 'us';

    const cToF = (tempC) => Math.round((tempC * 9) / 5 + 32);
    const kmhToMph = (kmh) => Math.round(Number(kmh) * 0.621371);
    const round = (value) => Math.round(Number(value));
    const formatTemp = (tempC) => unitSystem === 'us' ? `${cToF(tempC)}F` : `${round(tempC)}C`;
    const formatAltTemp = (tempC) => unitSystem === 'us' ? `${round(tempC)}C` : `${cToF(tempC)}F`;
    const formatWind = (kmh) => unitSystem === 'us' ? `${kmhToMph(kmh)} mph` : `${round(kmh)} km/h`;
    const formatPrecip = (mm) => unitSystem === 'us' ? `${(Number(mm || 0) / 25.4).toFixed(2)} in` : `${Number(mm || 0).toFixed(1)} mm`;
    const formatVisibility = (meters) => {
      if (meters === undefined || meters === null) return 'n/a';
      const km = Number(meters) / 1000;
      return unitSystem === 'us' ? `${(km * 0.621371).toFixed(1)} mi` : `${km.toFixed(1)} km`;
    };
    const windCompass = (degrees) => {
      const directions = ['N', 'NNE', 'NE', 'ENE', 'E', 'ESE', 'SE', 'SSE', 'S', 'SSW', 'SW', 'WSW', 'W', 'WNW', 'NW', 'NNW'];
      return directions[Math.round(Number(degrees) / 22.5) % 16];
    };
    const formatDay = (dateString) => new Intl.DateTimeFormat('en-US', { weekday: 'short' }).format(new Date(`${dateString}T12:00:00`));
    const formatDate = (dateString) => new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' }).format(new Date(`${dateString}T12:00:00`));
    const formatTime = (dateTimeString) => {
      const time = dateTimeString.split('T')[1] || dateTimeString;
      const [rawHour, minute] = time.split(':');
      const hour = Number(rawHour);
      const suffix = hour >= 12 ? 'PM' : 'AM';
      const hour12 = hour % 12 || 12;
      return `${hour12}:${minute} ${suffix}`;
    };
    const formatUpdated = (dateString) => {
      const [datePart] = dateString.split('T');
      return `${formatDate(datePart)}, ${formatTime(dateString)} Valle local`;
    };
    const cloudClass = (cover) => {
      if (cover < 25) return 'cloud-icon--clear';
      if (cover < 65) return 'cloud-icon--partly';
      return 'cloud-icon--cloudy';
    };
    const weatherLabel = (code) => {
      const labels = {
        0: 'Clear',
        1: 'Mainly clear',
        2: 'Partly cloudy',
        3: 'Overcast',
        45: 'Fog',
        48: 'Rime fog',
        51: 'Light drizzle',
        53: 'Drizzle',
        55: 'Heavy drizzle',
        61: 'Light rain',
        63: 'Rain',
        65: 'Heavy rain',
        80: 'Rain showers',
        81: 'Rain showers',
        82: 'Heavy showers',
        95: 'Thunderstorm',
        96: 'Thunderstorm',
        99: 'Thunderstorm'
      };
      return labels[Number(code)] || 'Weather update';
    };
    const conditionTone = (current, today) => {
      const wind = Number(current.wind_speed_10m);
      const gust = Number(current.wind_gusts_10m || wind);
      const precip = Number(today.precipitation_probability_max || 0);

      if (wind <= 16 && gust <= 24 && precip <= 25) return { label: 'Calmer town trend', className: 'is-good' };
      if (wind <= 24 && gust <= 34 && precip <= 45) return { label: 'Mixed town trend', className: 'is-watch' };
      return { label: 'Weather to watch', className: 'is-caution' };
    };
    const getHourlyStartIndex = (hourly, currentTime) => {
      const index = hourly.time.findIndex((time) => time >= currentTime);
      return index >= 0 ? index : 0;
    };
    const getHourlyPoint = (hourly, index) => ({
      time: hourly.time[index],
      temp: hourly.temperature_2m[index],
      apparent: hourly.apparent_temperature[index],
      humidity: hourly.relative_humidity_2m[index],
      precip: hourly.precipitation_probability[index] ?? 0,
      precipitation: hourly.precipitation[index] ?? 0,
      showers: hourly.showers[index] ?? 0,
      cloud: hourly.cloud_cover[index],
      wind: hourly.wind_speed_10m[index],
      direction: hourly.wind_direction_10m[index],
      gust: hourly.wind_gusts_10m[index],
      uv: hourly.uv_index[index] ?? 0,
      visibility: hourly.visibility[index]
    });
    const metricRow = (label, value) => `<div class="metric-row"><span>${label}</span><strong>${value}</strong></div>`;

    // Cloudbase estimate using Magnus formula for dewpoint, then 125m * spread.
    // Returns elevation ASL (feet and meters) plus height above launch (7,600 ft).
    const VALLE_TOWN_ELEVATION_M = 1800;
    const LAUNCH_ELEVATION_FT = 7600;
    const estimateCloudbase = (tempC, humidity) => {
      const t = Number(tempC);
      const rh = Number(humidity);
      if (!Number.isFinite(t) || !Number.isFinite(rh) || rh <= 0) return null;
      const a = 17.625;
      const b = 243.04;
      const alpha = Math.log(rh / 100) + (a * t) / (b + t);
      const dewpoint = (b * alpha) / (a - alpha);
      const baseAboveSurfaceM = 125 * (t - dewpoint);
      if (!Number.isFinite(baseAboveSurfaceM) || baseAboveSurfaceM < 0) return null;
      const aslM = VALLE_TOWN_ELEVATION_M + baseAboveSurfaceM;
      const aslFt = aslM * 3.28084;
      const aboveLaunchFt = aslFt - LAUNCH_ELEVATION_FT;
      return {
        aslM: Math.round(aslM / 50) * 50,
        aslFt: Math.round(aslFt / 100) * 100,
        aboveLaunchFt: Math.round(aboveLaunchFt / 100) * 100
      };
    };
    const formatCloudbase = (tempC, humidity) => {
      const cb = estimateCloudbase(tempC, humidity);
      if (!cb) return 'n/a';
      const aboveLaunch = cb.aboveLaunchFt > 0
        ? `+${cb.aboveLaunchFt.toLocaleString()} ft over launch`
        : `${cb.aboveLaunchFt.toLocaleString()} ft - below launch`;
      const primary = unitSystem === 'us'
        ? `${cb.aslFt.toLocaleString()} ft ASL`
        : `${cb.aslM.toLocaleString()} m ASL`;
      return `${primary} (${aboveLaunch})`;
    };

    // Paragliding flyability score 0-5 from a daily forecast row.
    // Inputs: wind_speed_10m_max (km/h), wind_gusts_10m_max (km/h),
    // cloud_cover_mean (%), precipitation_probability_max (%).
    const flyabilityScore = (wind, gust, cloud, precip) => {
      const w = Number(wind) || 0;
      const g = Number(gust) || 0;
      const c = Number(cloud) || 0;
      const p = Number(precip) || 0;

      // Wind: ideal 5-19 km/h. Light wind still flyable. Strong wind grounds you.
      let windScore;
      if (w < 5) windScore = 0.55;
      else if (w <= 19) windScore = 1.0;
      else if (w <= 28) windScore = 0.6;
      else if (w <= 36) windScore = 0.3;
      else windScore = 0.05;

      // Gusts: anything over 35 km/h is sketchy.
      let gustScore;
      if (g <= 25) gustScore = 1.0;
      else if (g <= 35) gustScore = 0.65;
      else if (g <= 45) gustScore = 0.35;
      else gustScore = 0.1;

      // Cloud cover: 25-75% is the sweet spot for cumulus. Blue sky still works.
      let cloudScore;
      if (c < 15) cloudScore = 0.75;
      else if (c <= 75) cloudScore = 1.0;
      else if (c <= 90) cloudScore = 0.5;
      else cloudScore = 0.2;

      // Precip probability: under 20% is good.
      let precipScore;
      if (p < 20) precipScore = 1.0;
      else if (p < 40) precipScore = 0.65;
      else if (p < 60) precipScore = 0.35;
      else precipScore = 0.1;

      const weighted = windScore * 0.35 + gustScore * 0.25 + cloudScore * 0.2 + precipScore * 0.2;
      return Math.round(weighted * 5 * 10) / 10;
    };
    const flyabilityLabel = (score) => {
      if (score >= 4.2) return 'Excellent';
      if (score >= 3.4) return 'Good';
      if (score >= 2.5) return 'Marginal';
      if (score >= 1.5) return 'Poor';
      return 'No fly';
    };
    const flyabilityClass = (score) => {
      if (score >= 4.2) return 'fly-score--excellent';
      if (score >= 3.4) return 'fly-score--good';
      if (score >= 2.5) return 'fly-score--marginal';
      if (score >= 1.5) return 'fly-score--poor';
      return 'fly-score--nofly';
    };
    const flyBadge = (score) => `
      <span class="fly-score ${flyabilityClass(score)}" aria-label="Flyability score ${score} out of 5">
        <strong>${score.toFixed(1)}</strong>
        <span>${flyabilityLabel(score)}</span>
      </span>
    `;
    const toTempNumber = (tempC) => unitSystem === 'us' ? (Number(tempC) * 9) / 5 + 32 : Number(tempC);
    const toWindNumber = (kmh) => unitSystem === 'us' ? Number(kmh) * 0.621371 : Number(kmh);
    const toPrecipNumber = (mm) => unitSystem === 'us' ? Number(mm || 0) / 25.4 : Number(mm || 0);
    const niceCeil = (value, step) => Math.ceil(value / step) * step;
    const pathFromPoints = (points) => points.map((point, index) => `${index === 0 ? 'M' : 'L'}${point.x.toFixed(1)} ${point.y.toFixed(1)}`).join(' ');
    const areaPath = (points, baseline) => `${pathFromPoints(points)} L${points[points.length - 1].x.toFixed(1)} ${baseline.toFixed(1)} L${points[0].x.toFixed(1)} ${baseline.toFixed(1)} Z`;
    const getDatePart = (dateTimeString) => dateTimeString.split('T')[0];
    const getHourPart = (dateTimeString) => Number((dateTimeString.split('T')[1] || '00:00').split(':')[0]);
    const axisTicks = (min, max, count) => Array.from({ length: count }, (_, index) => min + ((max - min) * index) / (count - 1));

    function renderMeteogram(hourly, currentTime) {
      if (!meteogramEl) return;

      const startIndex = getHourlyStartIndex(hourly, currentTime);
      const count = Math.min(120, hourly.time.length - startIndex);
      const points = hourly.time.slice(startIndex, startIndex + count).map((time, offset) => getHourlyPoint(hourly, startIndex + offset));

      if (points.length < 2) {
        meteogramEl.innerHTML = '<p class="weather-error">Not enough hourly data to draw the meteogram.</p>';
        return;
      }

      const width = 1180;
      const height = 760;
      const left = 88;
      const right = 60;
      const chartWidth = width - left - right;
      const stepX = chartWidth / (points.length - 1);
      const tempPanel = { y: 96, h: 220 };
      const precipPanel = { y: 360, h: 142 };
      const windPanel = { y: 548, h: 108 };
      const panelBottom = windPanel.y + windPanel.h;
      const xFor = (index) => left + index * stepX;

      const tempValues = points.map((point) => toTempNumber(point.temp));
      const rawTempMin = Math.min(...tempValues);
      const rawTempMax = Math.max(...tempValues);
      const tempMin = Math.floor((rawTempMin - 4) / 5) * 5;
      const tempMax = Math.ceil((rawTempMax + 4) / 5) * 5;
      const yTemp = (value) => tempPanel.y + tempPanel.h - ((value - tempMin) / (tempMax - tempMin)) * tempPanel.h;

      const precipValues = points.map((point) => toPrecipNumber(point.precipitation));
      const showerValues = points.map((point) => toPrecipNumber(point.showers));
      const precipMax = Math.max(unitSystem === 'us' ? 0.04 : 1, niceCeil(Math.max(...precipValues, ...showerValues), unitSystem === 'us' ? 0.02 : 0.5));
      const yPrecip = (value) => precipPanel.y + precipPanel.h - (value / precipMax) * precipPanel.h;

      const windValues = points.flatMap((point) => [toWindNumber(point.wind), toWindNumber(point.gust)]);
      const windMax = Math.max(unitSystem === 'us' ? 25 : 40, niceCeil(Math.max(...windValues), unitSystem === 'us' ? 5 : 10));
      const yWind = (value) => windPanel.y + windPanel.h - (value / windMax) * windPanel.h;

      const tempLinePoints = points.map((point, index) => ({ x: xFor(index), y: yTemp(toTempNumber(point.temp)) }));
      const gustLinePoints = points.map((point, index) => ({ x: xFor(index), y: yWind(toWindNumber(point.gust)) }));
      const windLinePoints = points.map((point, index) => ({ x: xFor(index), y: yWind(toWindNumber(point.wind)) }));
      const cloudLinePoints = points.map((point, index) => ({
        x: xFor(index),
        y: precipPanel.y + (1 - Number(point.cloud) / 100) * (precipPanel.h * 0.72)
      }));

      const daySegments = [];
      let segmentStart = 0;
      for (let index = 1; index < points.length; index += 1) {
        if (getDatePart(points[index].time) !== getDatePart(points[index - 1].time)) {
          daySegments.push({ start: segmentStart, end: index - 1, date: getDatePart(points[index - 1].time) });
          segmentStart = index;
        }
      }
      daySegments.push({ start: segmentStart, end: points.length - 1, date: getDatePart(points[points.length - 1].time) });

      const nightBands = points.map((point, index) => {
        const hour = getHourPart(point.time);
        if (hour >= 7 && hour < 19) return '';
        return `<rect x="${(xFor(index) - stepX / 2).toFixed(1)}" y="${tempPanel.y}" width="${(stepX + 1).toFixed(1)}" height="${panelBottom - tempPanel.y}" fill="#12151c" opacity="0.72" />`;
      }).join('');

      const dayLabels = daySegments.map((segment) => {
        const middle = (xFor(segment.start) + xFor(segment.end)) / 2;
        const isCurrentDay = segment.start === 0;
        return `
          <line x1="${xFor(segment.start).toFixed(1)}" y1="${tempPanel.y}" x2="${xFor(segment.start).toFixed(1)}" y2="${panelBottom}" stroke="#5d6670" stroke-width="1" />
          <text x="${middle.toFixed(1)}" y="74" fill="${isCurrentDay ? '#ff6a4a' : '#f5f7fb'}" font-size="18" font-weight="800" text-anchor="middle">${formatDay(segment.date)}</text>
          <text x="${middle.toFixed(1)}" y="96" fill="${isCurrentDay ? '#ff6a4a' : '#f5f7fb'}" font-size="16" font-weight="700" text-anchor="middle">${segment.date.slice(8)}.${segment.date.slice(5, 7)}</text>
        `;
      }).join('');

      const hourTicks = points.map((point, index) => {
        const hour = getHourPart(point.time);
        if (hour % 6 !== 0) return '';
        const x = xFor(index);
        const label = hour === 0 ? formatDay(getDatePart(point.time)) : String(hour).padStart(2, '0');
        return `
          <line x1="${x.toFixed(1)}" y1="${tempPanel.y}" x2="${x.toFixed(1)}" y2="${panelBottom}" stroke="#ffffff" stroke-opacity="0.12" />
          <text x="${x.toFixed(1)}" y="${tempPanel.y + tempPanel.h + 24}" fill="#f5f7fb" font-size="15" text-anchor="middle">${label}</text>
          <text x="${x.toFixed(1)}" y="${precipPanel.y + precipPanel.h + 24}" fill="#f5f7fb" font-size="15" text-anchor="middle">${label}</text>
          <text x="${x.toFixed(1)}" y="${windPanel.y + windPanel.h + 24}" fill="#f5f7fb" font-size="15" text-anchor="middle">${label}</text>
        `;
      }).join('');

      const tempGrid = axisTicks(tempMin, tempMax, 5).map((tick) => {
        const y = yTemp(tick);
        return `
          <line x1="${left}" y1="${y.toFixed(1)}" x2="${width - right}" y2="${y.toFixed(1)}" stroke="#ffffff" stroke-opacity="0.16" stroke-dasharray="2 4" />
          <text x="${left - 10}" y="${(y + 5).toFixed(1)}" fill="#f5f7fb" font-size="15" text-anchor="end">${Math.round(tick)}</text>
        `;
      }).join('');

      const precipGrid = axisTicks(0, precipMax, 4).map((tick) => {
        const y = yPrecip(tick);
        const label = unitSystem === 'us' ? tick.toFixed(2).replace(/^0/, '0') : tick.toFixed(1);
        return `
          <line x1="${left}" y1="${y.toFixed(1)}" x2="${width - right}" y2="${y.toFixed(1)}" stroke="#ffffff" stroke-opacity="0.14" stroke-dasharray="2 4" />
          <text x="${left - 10}" y="${(y + 5).toFixed(1)}" fill="#f5f7fb" font-size="15" text-anchor="end">${label}</text>
        `;
      }).join('');

      const windGrid = axisTicks(0, windMax, 4).map((tick) => {
        const y = yWind(tick);
        return `
          <line x1="${left}" y1="${y.toFixed(1)}" x2="${width - right}" y2="${y.toFixed(1)}" stroke="#ffffff" stroke-opacity="0.14" stroke-dasharray="2 4" />
          <text x="${left - 10}" y="${(y + 5).toFixed(1)}" fill="#f5f7fb" font-size="15" text-anchor="end">${Math.round(tick)}</text>
        `;
      }).join('');

      const precipBars = points.map((point, index) => {
        const value = toPrecipNumber(point.precipitation);
        const showerValue = toPrecipNumber(point.showers);
        const x = xFor(index) - Math.max(2, stepX * 0.22);
        const barWidth = Math.max(2, stepX * 0.44);
        const precipHeight = precipPanel.y + precipPanel.h - yPrecip(value);
        const showerHeight = precipPanel.y + precipPanel.h - yPrecip(showerValue);
        return `
          ${value > 0 ? `<rect x="${x.toFixed(1)}" y="${yPrecip(value).toFixed(1)}" width="${barWidth.toFixed(1)}" height="${precipHeight.toFixed(1)}" fill="#1a35ff" />` : ''}
          ${showerValue > 0 ? `<rect x="${(x + barWidth * 0.42).toFixed(1)}" y="${yPrecip(showerValue).toFixed(1)}" width="${(barWidth * 0.45).toFixed(1)}" height="${showerHeight.toFixed(1)}" fill="#7ee6f2" />` : ''}
        `;
      }).join('');

      const windArrows = points.map((point, index) => {
        if (index % 6 !== 0) return '';
        const x = xFor(index);
        const rotation = Number(point.direction) + 180;
        return `
          <g transform="translate(${x.toFixed(1)} ${windPanel.y + 14}) rotate(${rotation})">
            <line x1="-10" y1="0" x2="10" y2="0" stroke="#f5f7fb" stroke-width="2.5" stroke-linecap="round" />
            <path d="M10 0 L3 -5 L3 5 Z" fill="#f5f7fb" />
          </g>
        `;
      }).join('');

      const dailyHighLowLabels = daySegments.map((segment) => {
        const segmentPoints = points.slice(segment.start, segment.end + 1);
        const temps = segmentPoints.map((point) => toTempNumber(point.temp));
        const high = Math.max(...temps);
        const low = Math.min(...temps);
        const highPointIndex = segment.start + temps.indexOf(high);
        const lowPointIndex = segment.start + temps.indexOf(low);
        return `
          <text x="${xFor(highPointIndex).toFixed(1)}" y="${(yTemp(high) + 18).toFixed(1)}" fill="#151a20" font-size="17" font-weight="900" text-anchor="middle">${Math.round(high)}</text>
          <text x="${xFor(lowPointIndex).toFixed(1)}" y="${(yTemp(low) - 8).toFixed(1)}" fill="#f5f7fb" font-size="16" font-weight="800" text-anchor="middle">${Math.round(low)}</text>
        `;
      }).join('');

      meteogramEl.innerHTML = `
        <svg class="meteogram-svg" viewBox="0 0 ${width} ${height}" role="img" aria-label="5-day hourly meteogram for Valle de Bravo town">
          <defs>
            <linearGradient id="tempFill" x1="0" y1="${tempPanel.y}" x2="0" y2="${tempPanel.y + tempPanel.h}" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#ff2d2d" />
              <stop offset="28%" stop-color="#f6ee26" />
              <stop offset="52%" stop-color="#8ded2f" />
              <stop offset="75%" stop-color="#0aa15c" />
              <stop offset="100%" stop-color="#00d66b" />
            </linearGradient>
          </defs>

          <rect x="0" y="0" width="${width}" height="${height}" rx="6" fill="#211c1f" />
          <text x="24" y="38" fill="#ffffff" font-size="28" font-weight="900">Valle de Bravo</text>
          <text x="24" y="68" fill="#ffffff" font-size="19" font-weight="700">19.18N, 100.13W - town level weather</text>
          <text x="${width - 24}" y="42" fill="#e07730" font-size="22" font-weight="900" text-anchor="end">Air Damien</text>

          <rect x="${left}" y="${tempPanel.y}" width="${chartWidth}" height="${panelBottom - tempPanel.y}" fill="#2f3f49" opacity="0.78" />
          ${nightBands}
          ${dayLabels}
          ${hourTicks}

          <rect x="${left}" y="${tempPanel.y}" width="${chartWidth}" height="${tempPanel.h}" fill="none" stroke="#7f858d" stroke-width="1" />
          ${tempGrid}
          <path d="${areaPath(tempLinePoints, tempPanel.y + tempPanel.h)}" fill="url(#tempFill)" opacity="0.96" />
          <path d="${pathFromPoints(tempLinePoints)}" fill="none" stroke="#ff1717" stroke-width="5" stroke-linejoin="round" stroke-linecap="round" />
          ${dailyHighLowLabels}
          <text x="30" y="${tempPanel.y + tempPanel.h / 2}" fill="#f5f7fb" font-size="17" font-weight="800" transform="rotate(-90 30 ${tempPanel.y + tempPanel.h / 2})">Temperature (${unitSystem === 'us' ? 'F' : 'C'})</text>

          <rect x="${left}" y="${precipPanel.y}" width="${chartWidth}" height="${precipPanel.h}" fill="none" stroke="#7f858d" stroke-width="1" />
          ${precipGrid}
          <path d="${pathFromPoints(cloudLinePoints)} L${xFor(points.length - 1).toFixed(1)} ${precipPanel.y} L${xFor(0).toFixed(1)} ${precipPanel.y} Z" fill="#d5d8dc" opacity="0.68" />
          ${precipBars}
          <text x="30" y="${precipPanel.y + precipPanel.h / 2}" fill="#f5f7fb" font-size="17" font-weight="800" transform="rotate(-90 30 ${precipPanel.y + precipPanel.h / 2})">Precipitation (${unitSystem === 'us' ? 'in/hr' : 'mm/hr'})</text>

          <rect x="${left}" y="${windPanel.y}" width="${chartWidth}" height="${windPanel.h}" fill="none" stroke="#7f858d" stroke-width="1" />
          ${windGrid}
          ${windArrows}
          <path d="${pathFromPoints(gustLinePoints)}" fill="none" stroke="#11a6a8" stroke-width="3.5" stroke-linejoin="round" stroke-linecap="round" />
          <path d="${pathFromPoints(windLinePoints)}" fill="none" stroke="#4fbaff" stroke-width="4.5" stroke-linejoin="round" stroke-linecap="round" />
          <text x="30" y="${windPanel.y + windPanel.h / 2}" fill="#4fbaff" font-size="17" font-weight="800" transform="rotate(-90 30 ${windPanel.y + windPanel.h / 2})">Wind speed (${unitSystem === 'us' ? 'mph' : 'km/h'})</text>
          <text x="${width - 18}" y="${windPanel.y + windPanel.h / 2}" fill="#11d3d5" font-size="17" font-weight="800" transform="rotate(90 ${width - 18} ${windPanel.y + windPanel.h / 2})">Wind gust (${unitSystem === 'us' ? 'mph' : 'km/h'})</text>

          <g transform="translate(${left + 20} ${height - 30})">
            <circle cx="0" cy="0" r="7" fill="#d5d8dc" opacity="0.75" /><text x="18" y="6" fill="#f5f7fb" font-size="16" font-weight="800">Cloud cover</text>
            <circle cx="154" cy="0" r="7" fill="#1a35ff" /><text x="172" y="6" fill="#f5f7fb" font-size="16" font-weight="800">Precipitation</text>
            <circle cx="348" cy="0" r="7" fill="#7ee6f2" /><text x="366" y="6" fill="#f5f7fb" font-size="16" font-weight="800">Showers</text>
            <line x1="530" y1="0" x2="570" y2="0" stroke="#4fbaff" stroke-width="5" stroke-linecap="round" /><text x="584" y="6" fill="#f5f7fb" font-size="16" font-weight="800">Wind</text>
            <line x1="670" y1="0" x2="710" y2="0" stroke="#11a6a8" stroke-width="4" stroke-linecap="round" /><text x="724" y="6" fill="#f5f7fb" font-size="16" font-weight="800">Gusts</text>
          </g>
        </svg>
        <p class="meteogram-caption">Graph data source: Open-Meteo model data for Valle de Bravo town coordinates, including the wind and gust lines shown here. Last updated: ${formatUpdated(weatherData.current.time)}. For launch-level wind, use the Holfuy and Windguru links above.</p>
      `;
    }

    function renderWeather() {
      if (!weatherData || !currentEl || !planningEl || !meteogramEl || !hourlyEl || !forecastEl) return;

      const current = weatherData.current;
      const daily = weatherData.daily;
      const hourly = weatherData.hourly;
      const today = {
        weather_code: daily.weather_code[0],
        temperature_2m_max: daily.temperature_2m_max[0],
        temperature_2m_min: daily.temperature_2m_min[0],
        apparent_temperature_max: daily.apparent_temperature_max[0],
        wind_speed_10m_max: daily.wind_speed_10m_max[0],
        wind_gusts_10m_max: daily.wind_gusts_10m_max[0],
        wind_direction_10m_dominant: daily.wind_direction_10m_dominant[0],
        cloud_cover_mean: daily.cloud_cover_mean[0],
        precipitation_probability_max: daily.precipitation_probability_max[0] ?? 0,
        uv_index_max: daily.uv_index_max[0] ?? 0,
        sunrise: daily.sunrise[0],
        sunset: daily.sunset[0]
      };
      const startIndex = getHourlyStartIndex(hourly, current.time);
      const currentHour = getHourlyPoint(hourly, startIndex);
      const tone = conditionTone(current, today);
      const compassRotation = Number(current.wind_direction_10m) + 180;

      currentEl.innerHTML = `
        <div class="current-hero">
          <div>
            <p class="condition-label">${weatherLabel(current.weather_code)}</p>
            <div class="current-temp">
              <span class="current-temp__value">${formatTemp(current.temperature_2m)}</span>
              <span class="current-temp__alt">${formatAltTemp(current.temperature_2m)}</span>
            </div>
            <p class="feels-like">Feels like ${formatTemp(current.apparent_temperature)} at town level</p>
          </div>
          <div class="wind-compass" aria-label="Wind from ${windCompass(current.wind_direction_10m)}">
            <span class="wind-compass__arrow" style="transform: rotate(${compassRotation}deg)"></span>
            <strong>${windCompass(current.wind_direction_10m)}</strong>
          </div>
        </div>

        <div class="condition-badge ${tone.className}">
          <span>${tone.label}</span>
          <strong>${formatUpdated(current.time)}</strong>
        </div>

        <div class="current-metrics">
          ${metricRow('Wind', `${formatWind(current.wind_speed_10m)} ${windCompass(current.wind_direction_10m)}`)}
          ${metricRow('Gusts', formatWind(current.wind_gusts_10m || current.wind_speed_10m))}
          ${metricRow('Humidity', `${round(current.relative_humidity_2m)}%`)}
          ${metricRow('Cloud cover', `${round(current.cloud_cover)}%`)}
          ${metricRow('Est. cloudbase', formatCloudbase(current.temperature_2m, current.relative_humidity_2m))}
          ${metricRow('Pressure', `${round(current.surface_pressure)} hPa`)}
          ${metricRow('Precip now', formatPrecip(current.precipitation))}
          ${metricRow('UV now', Number(currentHour.uv || 0).toFixed(1))}
          ${metricRow('Visibility', formatVisibility(currentHour.visibility))}
        </div>
      `;

      const todayScore = flyabilityScore(today.wind_speed_10m_max, today.wind_gusts_10m_max, today.cloud_cover_mean, today.precipitation_probability_max);

      planningEl.innerHTML = `
        <div class="planning-card__header">
          <div>
            <p class="weather-card__label">Today</p>
            <h3>${weatherLabel(today.weather_code)}</h3>
          </div>
          ${flyBadge(todayScore)}
        </div>
        <div class="planning-stats">
          <div>
            <span>High / low</span>
            <strong>${formatTemp(today.temperature_2m_max)} / ${formatTemp(today.temperature_2m_min)}</strong>
          </div>
          <div>
            <span>Max wind</span>
            <strong>${formatWind(today.wind_speed_10m_max)} ${windCompass(today.wind_direction_10m_dominant)}</strong>
          </div>
          <div>
            <span>Max gust</span>
            <strong>${formatWind(today.wind_gusts_10m_max)}</strong>
          </div>
          <div>
            <span>Precip chance</span>
            <strong>${round(today.precipitation_probability_max)}%</strong>
          </div>
          <div>
            <span>Cloud mean</span>
            <strong>${round(today.cloud_cover_mean)}%</strong>
          </div>
          <div>
            <span>UV max</span>
            <strong>${Number(today.uv_index_max).toFixed(1)}</strong>
          </div>
        </div>
        <div class="sun-row">
          <span>Sunrise ${formatTime(today.sunrise)}</span>
          <span>Sunset ${formatTime(today.sunset)}</span>
        </div>
      `;

      hourlyEl.innerHTML = hourly.time.slice(startIndex, startIndex + 12).map((time, offset) => {
        const point = getHourlyPoint(hourly, startIndex + offset);
        const calm = Number(point.wind) <= 20 && Number(point.precip) <= 30;

        return `
          <article class="hour-card${calm ? ' is-calm' : ''}">
            <strong>${offset === 0 ? 'Now' : formatTime(time)}</strong>
            <span class="cloud-icon ${cloudClass(point.cloud)}" aria-label="${round(point.cloud)}% cloud cover"></span>
            <div class="hour-card__temp">${formatTemp(point.temp)}</div>
            <dl>
              <div><dt>Wind</dt><dd>${formatWind(point.wind)}</dd></div>
              <div><dt>Gust</dt><dd>${formatWind(point.gust)}</dd></div>
              <div><dt>Precip</dt><dd>${round(point.precip)}%</dd></div>
              <div><dt>Cloud</dt><dd>${round(point.cloud)}%</dd></div>
            </dl>
          </article>
        `;
      }).join('');

      forecastEl.innerHTML = daily.time.map((date, index) => {
        const high = daily.temperature_2m_max[index];
        const low = daily.temperature_2m_min[index];
        const wind = daily.wind_speed_10m_max[index];
        const gust = daily.wind_gusts_10m_max[index];
        const direction = daily.wind_direction_10m_dominant[index];
        const cloud = round(daily.cloud_cover_mean[index]);
        const precip = round(daily.precipitation_probability_max[index] ?? 0);
        const score = flyabilityScore(wind, gust, daily.cloud_cover_mean[index], daily.precipitation_probability_max[index]);
        const flyable = score >= 3.4;

        return `
          <article class="forecast-day${flyable ? ' is-flyable' : ''}">
            <div class="forecast-day__top">
              <div>
                <strong>${formatDay(date)}</strong>
                <span>${formatDate(date)}</span>
              </div>
              ${flyBadge(score)}
            </div>
            <span class="cloud-icon ${cloudClass(cloud)}" aria-label="${cloud}% cloud cover"></span>
            <div class="forecast-day__condition">${weatherLabel(daily.weather_code[index])}</div>
            <div class="forecast-day__temps">${formatTemp(high)} / ${formatTemp(low)}</div>
            <dl>
              <div><dt>Wind</dt><dd>${formatWind(wind)} ${windCompass(direction)}</dd></div>
              <div><dt>Gust</dt><dd>${formatWind(gust)}</dd></div>
              <div><dt>Cloud</dt><dd>${cloud}%</dd></div>
              <div><dt>Precip</dt><dd>${precip}%</dd></div>
            </dl>
          </article>
          `;
      }).join('');

      renderMeteogram(hourly, current.time);
    }

    unitButtons.forEach((button) => {
      button.addEventListener('click', () => {
        unitSystem = button.getAttribute('data-unit-system') || 'us';
        unitButtons.forEach((unitButton) => {
          const isActive = unitButton === button;
          unitButton.classList.toggle('is-active', isActive);
          unitButton.setAttribute('aria-pressed', String(isActive));
        });
        renderWeather();
      });
    });

    async function loadWeather() {
      if (!widget || !statusEl || !currentEl || !planningEl || !meteogramEl || !hourlyEl || !forecastEl) return;

      try {
        const response = await fetch(weatherUrl);
        if (!response.ok) throw new Error('Weather request failed');

        weatherData = await response.json();

        statusEl.textContent = 'Live data';
        statusEl.classList.add('is-live');
        renderWeather();
      } catch (error) {
        statusEl.textContent = 'Weather unavailable';
        currentEl.innerHTML = '<p class="weather-error">The live weather feed is not available right now. Please try again later.</p>';
        planningEl.innerHTML = '<p class="weather-error">Today\'s planning data could not be loaded.</p>';
        meteogramEl.innerHTML = '<p class="weather-error">Meteogram data could not be loaded.</p>';
        hourlyEl.innerHTML = '<p class="weather-error">Hourly outlook could not be loaded.</p>';
        forecastEl.innerHTML = '<p class="weather-error">Forecast data could not be loaded.</p>';
      }
    }

    loadWeather();

    // ============================================================
    // Holfuy launch data (via /api/holfuy proxy) + webcam auto-refresh.
    // The proxy parses Holfuy's public widget HTML server-side and
    // returns JSON so we can render in our own UI.
    // ============================================================

    const holfuyPanel = document.querySelector('[data-holfuy-panel]');
    const holfuyDataEl = document.querySelector('[data-holfuy-data]');
    const holfuyFallbackEl = document.querySelector('[data-holfuy-fallback]');
    const holfuyCameraImg = document.querySelector('[data-holfuy-camera]');
    const holfuyCameraUpdated = document.querySelector('[data-holfuy-camera-updated]');
    const holfuyFreshnessEl = document.querySelector('[data-holfuy-freshness]');
    const holfuyTrendEl = document.querySelector('[data-holfuy-trend]');
    const holfuyTrendSummaryEl = document.querySelector('[data-holfuy-trend-summary]');
    const holfuySparklineEl = document.querySelector('[data-holfuy-sparkline]');

    // Anchors for live-updating relative timestamps.
    // We track "when did the underlying reading come in" as a Date,
    // then refresh the displayed string every 5 seconds.
    let holfuyReadingTakenAt = null;
    let cameraFrameTakenAt = null;

    function setText(selector, text) {
      const el = document.querySelector(selector);
      if (el) el.textContent = text;
    }

    function dirToDegrees(label) {
      // Map cardinal/intercardinal labels to degrees for compass arrow.
      // Holfuy returns labels like "SW", "WSW", "N", etc.
      const map = {
        N: 0, NNE: 22.5, NE: 45, ENE: 67.5,
        E: 90, ESE: 112.5, SE: 135, SSE: 157.5,
        S: 180, SSW: 202.5, SW: 225, WSW: 247.5,
        W: 270, WNW: 292.5, NW: 315, NNW: 337.5,
        VRB: null, '--': null
      };
      if (typeof label !== 'string') return null;
      return map[label.trim().toUpperCase()] ?? null;
    }

    function formatRelativeTime(secondsAgo) {
      if (!Number.isFinite(secondsAgo)) return 'just now';
      if (secondsAgo < 60) return `${Math.round(secondsAgo)} sec ago`;
      const m = Math.floor(secondsAgo / 60);
      if (m < 60) return `${m} min ${Math.round(secondsAgo % 60)} sec ago`;
      return `${Math.floor(m / 60)}h ${m % 60}m ago`;
    }

    function holfuyDirArrow(deg) {
      const arrow = document.querySelector('[data-holfuy-compass-arrow]');
      if (!arrow) return;
      if (deg === null || deg === undefined || !Number.isFinite(deg)) {
        arrow.style.opacity = '0.3';
        return;
      }
      arrow.style.opacity = '1';
      // SVG arrow points up (toward N). Holfuy direction is the bearing
      // the wind is coming FROM. Rotating by `deg` makes the arrow point
      // toward that bearing on the compass face - i.e., where the wind is
      // coming from. (Pilots read compass arrows as "wind FROM that direction".)
      arrow.style.transform = `rotate(${deg}deg)`;
      arrow.style.transformOrigin = '60px 60px';
    }

    function renderSparkline(readings) {
      if (!holfuySparklineEl) return;
      if (!readings || readings.length < 2) {
        holfuySparklineEl.innerHTML = '';
        return;
      }
      const speeds = readings.map(r => r.speedMph);
      const max = Math.max(...speeds, 1);
      const min = Math.min(...speeds, 0);
      const range = Math.max(max - min, 1);
      const w = 80;
      const h = 28;
      const step = w / (speeds.length - 1);
      const pts = speeds.map((v, i) => {
        const x = i * step;
        const y = h - ((v - min) / range) * h;
        return `${x.toFixed(1)},${y.toFixed(1)}`;
      });
      holfuySparklineEl.innerHTML = `
        <svg viewBox="0 0 ${w} ${h}" width="${w}" height="${h}" aria-hidden="true">
          <polyline points="${pts.join(' ')}" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          ${pts.map(p => {
            const [x, y] = p.split(',');
            return `<circle cx="${x}" cy="${y}" r="2" fill="currentColor" />`;
          }).join('')}
        </svg>
      `;
    }

    function trendCopy(trend) {
      if (!trend) return null;
      const speedDelta = trend.speedDeltaMph;
      const dirShift = trend.directionShiftDeg;
      const parts = [];
      if (trend.speedTrend === 'rising') parts.push(`Wind picking up (+${speedDelta.toFixed(1)} mph)`);
      else if (trend.speedTrend === 'dropping') parts.push(`Wind dropping (${speedDelta.toFixed(1)} mph)`);
      else parts.push('Wind steady');
      if (trend.directionShiftTrend === 'clocking-right') parts.push(`clocking right ${dirShift}°`);
      else if (trend.directionShiftTrend === 'clocking-left') parts.push(`clocking left ${dirShift}°`);
      return parts.join(' · ');
    }

    function applyHolfuy(data) {
      if (!data || data.ok === false) {
        showHolfuyFallback();
        return;
      }

      // Fill all data points - tolerate nulls.
      const wind = data.wind || {};
      const avg = data.avg15 || {};
      const daily = data.daily || {};
      const temp = data.temperature || {};
      const atmos = data.atmosphere || {};

      setText('[data-holfuy-speed]', wind.speedMph != null ? wind.speedMph.toFixed(1) : '--');
      setText('[data-holfuy-gust]', wind.gustMph != null ? wind.gustMph.toFixed(1) : '--');
      setText('[data-holfuy-dir]', wind.directionLabel || '--');
      setText('[data-holfuy-dir-text]', wind.directionLabel || '--');

      setText('[data-holfuy-avg-speed]', avg.speedMph != null ? avg.speedMph.toFixed(1) : '--');
      setText('[data-holfuy-avg-gust]', avg.maxGustMph != null ? avg.maxGustMph.toFixed(1) : '--');
      setText('[data-holfuy-avg-dir]', avg.directionLabel || '--');

      setText('[data-holfuy-daily-avg]', daily.avgSpeedMph != null ? daily.avgSpeedMph.toFixed(1) : '--');
      setText('[data-holfuy-daily-max]', daily.maxGustMph != null ? daily.maxGustMph.toFixed(1) : '--');

      setText('[data-holfuy-temp]', temp.airF != null ? temp.airF.toFixed(1) : '--');
      setText('[data-holfuy-temp-max]', temp.dailyMaxF != null ? temp.dailyMaxF.toFixed(1) : '--');
      setText('[data-holfuy-temp-min]', temp.dailyMinF != null ? temp.dailyMinF.toFixed(1) : '--');

      setText('[data-holfuy-humidity]', atmos.humidityPct != null ? atmos.humidityPct.toFixed(0) : '--');
      setText('[data-holfuy-cloudbase]', atmos.cloudBaseM != null ? atmos.cloudBaseM.toLocaleString() : '--');
      setText('[data-holfuy-pressure]', atmos.pressureHpa != null ? atmos.pressureHpa.toFixed(0) : '--');
      setText('[data-holfuy-rain]', atmos.rainMmToday != null ? atmos.rainMmToday.toFixed(1) : '0');

      // Cloud base relative to launch (7,600 ft / 2,316m)
      const cloudbaseLaunchEl = document.querySelector('[data-holfuy-cloudbase-launch]');
      if (cloudbaseLaunchEl && atmos.cloudBaseM != null) {
        const aboveLaunchM = atmos.cloudBaseM - 2316;
        const aboveLaunchFt = Math.round((aboveLaunchM * 3.28084) / 100) * 100;
        cloudbaseLaunchEl.textContent = aboveLaunchM > 0
          ? `+${aboveLaunchFt.toLocaleString()} ft over launch`
          : `${aboveLaunchFt.toLocaleString()} ft - below launch`;
      }

      // Use precise degrees from the latest recent reading if available,
      // falling back to the cardinal-label approximation.
      const recent = Array.isArray(data.recentReadings) ? data.recentReadings : [];
      const latestReading = recent[recent.length - 1];
      const preciseDeg = latestReading && Number.isFinite(latestReading.directionDeg)
        ? latestReading.directionDeg
        : dirToDegrees(wind.directionLabel);
      holfuyDirArrow(preciseDeg);

      // Trend summary + sparkline
      const trend = data.trend;
      const summary = trendCopy(trend);
      if (summary && holfuyTrendEl && holfuyTrendSummaryEl) {
        holfuyTrendSummaryEl.textContent = summary;
        holfuyTrendEl.dataset.trend = trend.speedTrend;
        holfuyTrendEl.hidden = false;
      } else if (holfuyTrendEl) {
        holfuyTrendEl.hidden = true;
      }
      renderSparkline(recent);

      // Anchor "X sec ago" to a wall-clock time so the displayed string
      // stays accurate as the user sits on the page.
      if (Number.isFinite(data.lastReadingSecondsAgo)) {
        holfuyReadingTakenAt = new Date(Date.now() - data.lastReadingSecondsAgo * 1000);
      } else {
        holfuyReadingTakenAt = new Date();
      }
      updateLiveTimestamps();

      // Camera freshness from server-side HEAD response.
      if (data.camera && Number.isFinite(data.camera.ageSeconds)) {
        cameraFrameTakenAt = new Date(Date.now() - data.camera.ageSeconds * 1000);
      } else if (data.camera && data.camera.lastModifiedIso) {
        cameraFrameTakenAt = new Date(data.camera.lastModifiedIso);
      }
      updateCameraTimestamp();

      if (holfuyDataEl) holfuyDataEl.hidden = false;
      if (holfuyFallbackEl) holfuyFallbackEl.hidden = true;
    }

    function updateLiveTimestamps() {
      if (holfuyFreshnessEl && holfuyReadingTakenAt) {
        const ageSec = Math.max(0, Math.floor((Date.now() - holfuyReadingTakenAt.getTime()) / 1000));
        holfuyFreshnessEl.innerHTML = `<span class="holfuy-panel__dot"></span> Reading ${formatRelativeTime(ageSec)}`;
        holfuyFreshnessEl.classList.add('is-live');
        holfuyFreshnessEl.classList.remove('is-error');
      }
    }

    function updateCameraTimestamp() {
      if (!holfuyCameraUpdated) return;
      if (!cameraFrameTakenAt) {
        holfuyCameraUpdated.textContent = 'frame age unknown';
        return;
      }
      const ageSec = Math.max(0, Math.floor((Date.now() - cameraFrameTakenAt.getTime()) / 1000));
      holfuyCameraUpdated.textContent = `frame ${formatRelativeTime(ageSec)}`;
    }

    function showHolfuyFallback() {
      if (holfuyDataEl) holfuyDataEl.hidden = true;
      if (holfuyFallbackEl) holfuyFallbackEl.hidden = false;
      if (holfuyFreshnessEl) {
        holfuyFreshnessEl.textContent = 'Live feed unavailable';
        holfuyFreshnessEl.classList.add('is-error');
      }
    }

    async function loadHolfuy() {
      if (!holfuyPanel) return;
      try {
        const response = await fetch('/api/holfuy', { cache: 'no-store' });
        if (!response.ok) throw new Error('proxy ' + response.status);
        const data = await response.json();
        applyHolfuy(data);
      } catch (err) {
        showHolfuyFallback();
      }
    }

    // Camera: bust cache so we get the latest image when the page loads,
    // then refresh every 60 seconds while the page is visible. Note the
    // *frame age* is set from the proxy's HEAD response (Last-Modified)
    // and updated independently below.
    function refreshCameraImage() {
      if (!holfuyCameraImg) return;
      const ts = Date.now();
      const base = 'https://api.holfuy.com/cam/s609.jpg';
      holfuyCameraImg.src = `${base}?ts=${ts}`;
    }

    if (holfuyPanel) {
      loadHolfuy();
      refreshCameraImage();
      // Re-fetch data + camera every 60s while the tab is visible.
      setInterval(() => {
        if (document.visibilityState === 'visible') {
          loadHolfuy();
          refreshCameraImage();
        }
      }, 60000);
      // Tick the relative timestamps every 5s so they stay live.
      setInterval(() => {
        updateLiveTimestamps();
        updateCameraTimestamp();
      }, 5000);
    }
  </script>
</BaseLayout>

