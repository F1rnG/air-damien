---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

const pageTitle = 'Valle de Bravo Paragliding Conditions: Weather, Thermals, and Season Guide | Air Damien';
const pageDescription = 'Check paragliding conditions in Valle de Bravo by month. Thermal patterns, temperature ranges, cloudbase estimates, wind patterns, and flyability ratings.';

const breadcrumbs = [
  { name: 'Home', url: 'https://airdamien.com/' },
  { name: 'Valle de Bravo Guide', url: 'https://airdamien.com/paragliding-valle-de-bravo/' },
  { name: 'Valle de Bravo Conditions', url: 'https://airdamien.com/valle-de-bravo-conditions/' }
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Valle de Bravo Paragliding Conditions',
  headline: 'Valle de Bravo Paragliding Conditions',
  description: pageDescription,
  url: 'https://airdamien.com/valle-de-bravo-conditions/',
  dateModified: '2026-05-03',
  author: {
    '@type': 'Person',
    name: 'Damien Mitchell',
    url: 'https://airdamien.com/about-us/',
    jobTitle: 'USHPA Advanced Instructor'
  },
  publisher: {
    '@type': 'Organization',
    name: 'Air Damien',
    url: 'https://airdamien.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://airdamien.com/images/logo.png'
    }
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://airdamien.com/valle-de-bravo-conditions/'
  },
  image: 'https://airdamien.com/images/val6.jpg'
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'When is the best month to paraglide Valle de Bravo?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'November through March is peak season, with the most consistent thermals, clearest skies, and lowest rain probability. November and February are the sweet spots for pilots who want peak conditions without the December crowds. December delivers the strongest XC conditions; January offers December-quality flying with cooler mornings.'
      }
    },
    {
      '@type': 'Question',
      name: 'Is Valle de Bravo flyable year-round?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Technically yes, but May through September is rainy season. Mornings can produce flyable thermals, but afternoon thunderstorms are common and conditions are unpredictable. We run guided trips November through April; rainy-season flying is for experienced local pilots only.'
      }
    },
    {
      '@type': 'Question',
      name: 'What does the Hair Dryer mean at El Penon?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The Hair Dryer is the local name for the daily thermal cycle at El Penon, which kicks on with remarkable consistency around 10:00 AM during peak season. The dark volcanic rock heats fast in the morning sun and produces strong, well-organized thermals you can almost set your watch by.'
      }
    },
    {
      '@type': 'Question',
      name: 'How accurate is the live weather feed on this page?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The live data is from Open-Meteo for Valle de Bravo town coordinates (19.1838, -100.1278) at roughly 5,000 ft elevation. Conditions at El Penon launch (7,600 ft) differ meaningfully - colder mornings, different wind patterns, stronger thermals. Use this page for trip planning. For actual go/no-go calls, check Holfuy launch wind and Windguru launch forecast.'
      }
    },
    {
      '@type': 'Question',
      name: 'How long is a typical Valle de Bravo flying day?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'During peak season the thermal window runs roughly 10:00 AM to 3:00 PM. That gives you 4 to 5 hours of usable conditions. Most pilots fly two sessions: a morning thermal flight and an afternoon glass-off session. Multi-hour single flights of 2 to 3 hours are common.'
      }
    },
    {
      '@type': 'Question',
      name: 'What rating do I need to fly Valle de Bravo?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'P2 (Novice) is the practical minimum. With guided instruction and radio coaching, P2 pilots fly El Penon safely and use it as a thermalling-skill accelerator. Mid-day flying in the strongest conditions is restricted to P4 pilots and above by local club rules.'
      }
    }
  ]
};

const monthlyConditions = [
  {
    name: 'November',
    slug: 'november',
    rating: 5,
    temp: '50-75F',
    thermals: 'Strong thermals',
    cloudbase: '9,500-10,500 ft',
    window: '10am-3pm',
    rain: 'Low rain',
    crowds: 'Moderate crowds',
    xc: 'Excellent XC',
    season: 'Peak',
    recommendation: 'One of the best all-around months for clean air, reliable cycles, and skill-building flights.'
  },
  {
    name: 'December',
    slug: 'december',
    rating: 5,
    temp: '50-75F',
    thermals: 'Strong thermals',
    cloudbase: '9,500-10,500 ft',
    window: '10am-3pm',
    rain: 'Low rain',
    crowds: 'High crowds',
    xc: 'Excellent XC',
    season: 'Peak',
    recommendation: 'Peak-season power and consistency, with the busiest launch environment of the year.'
  },
  {
    name: 'January',
    slug: 'january',
    rating: 5,
    temp: '48-73F',
    thermals: 'Strong thermals',
    cloudbase: '9,000-10,000 ft',
    window: '10am-2:30pm',
    rain: 'Low rain',
    crowds: 'Moderate crowds',
    xc: 'Excellent XC',
    season: 'Peak',
    recommendation: 'Excellent peak-season flying with cooler mornings and fewer holiday crowds.'
  },
  {
    name: 'February',
    slug: 'february',
    rating: 4.5,
    temp: '50-78F',
    thermals: 'Strong thermals',
    cloudbase: '9,500-10,500 ft',
    window: '10am-3pm',
    rain: 'Low rain',
    crowds: 'Low-moderate crowds',
    xc: 'Excellent XC',
    season: 'Peak',
    recommendation: 'A strong value month for pilots who want reliable conditions and smaller groups.'
  },
  {
    name: 'March',
    slug: 'march',
    rating: 4,
    temp: '55-82F',
    thermals: 'Moderate-strong thermals',
    cloudbase: '8,500-9,500 ft',
    window: '10am-2pm',
    rain: 'Increasing rain',
    crowds: 'Low crowds',
    xc: 'Good XC',
    season: 'Shoulder',
    recommendation: 'Good for flexible pilots who can work with a more variable shoulder-season pattern.'
  },
  {
    name: 'April',
    slug: 'april',
    rating: 3,
    temp: '58-85F',
    thermals: 'Moderate thermals',
    cloudbase: 'Variable',
    window: '10am-1pm',
    rain: 'Moderate rain',
    crowds: 'Low crowds',
    xc: 'Moderate XC',
    season: 'Shoulder',
    recommendation: 'Best for pilots with flexible dates and a willingness to fly around changing weather.'
  },
  {
    name: 'May',
    slug: 'may',
    rating: 2.5,
    temp: '60-85F',
    thermals: 'Moderate thermals',
    cloudbase: 'Variable',
    window: '10am-12pm',
    rain: 'High rain afternoons',
    crowds: 'Very low crowds',
    xc: 'Limited XC',
    season: 'Rainy',
    recommendation: 'A morning-focused rainy-season option, not a first choice for a fly-every-day trip.'
  },
  {
    name: 'June',
    slug: 'june',
    rating: 2,
    temp: '60-80F',
    thermals: 'Light-moderate thermals',
    cloudbase: 'Variable',
    window: 'Mornings only',
    rain: 'High rain',
    crowds: 'Very low crowds',
    xc: 'Limited XC',
    season: 'Rainy',
    recommendation: 'Rainy-season flying is mainly a local or flexible-pilot play.'
  },
  {
    name: 'July',
    slug: 'july',
    rating: 2,
    temp: '60-80F',
    thermals: 'Light-moderate thermals',
    cloudbase: 'Variable',
    window: 'Mornings only',
    rain: 'High rain',
    crowds: 'Very low crowds',
    xc: 'Limited XC',
    season: 'Rainy',
    recommendation: 'Expect morning chances and afternoon weather management rather than full flying days.'
  },
  {
    name: 'August',
    slug: 'august',
    rating: 2,
    temp: '60-80F',
    thermals: 'Light-moderate thermals',
    cloudbase: 'Variable',
    window: 'Mornings only',
    rain: 'High rain',
    crowds: 'Very low crowds',
    xc: 'Limited XC',
    season: 'Rainy',
    recommendation: 'Better for experienced pilots already in town than for a dedicated travel window.'
  },
  {
    name: 'September',
    slug: 'september',
    rating: 2,
    temp: '60-80F',
    thermals: 'Light-moderate thermals',
    cloudbase: 'Variable',
    window: 'Mornings only',
    rain: 'High rain',
    crowds: 'Very low crowds',
    xc: 'Limited XC',
    season: 'Rainy',
    recommendation: 'Still rainy-season flying, with useful mornings possible when the pattern cooperates.'
  },
  {
    name: 'October',
    slug: 'october',
    rating: 3,
    temp: '55-78F',
    thermals: 'Moderate thermals',
    cloudbase: 'Improving',
    window: '10am-1pm',
    rain: 'Decreasing rain',
    crowds: 'Low crowds',
    xc: 'Moderate XC',
    season: 'Shoulder',
    recommendation: 'The transition back toward peak season, with improving chances late in the month.'
  }
].map((month) => {
  const guideMonths = ['november', 'december', 'january', 'february', 'march'];
  return {
    ...month,
    ratingPercent: `${(month.rating / 5) * 100}%`,
    ratingLabel: `${month.rating}/5`,
    guideUrl: guideMonths.includes(month.slug) ? `/paragliding-valle-de-bravo-${month.slug}/` : null
  };
});

const guideLinks = [
  { name: 'November guide', href: '/paragliding-valle-de-bravo-november/' },
  { name: 'December guide', href: '/paragliding-valle-de-bravo-december/' },
  { name: 'January guide', href: '/paragliding-valle-de-bravo-january/' },
  { name: 'February guide', href: '/paragliding-valle-de-bravo-february/' },
  { name: 'March guide', href: '/paragliding-valle-de-bravo-march/' }
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl="https://airdamien.com/valle-de-bravo-conditions/"
>
  <SchemaMarkup schema={pageSchema} />
  <SchemaMarkup schema={faqSchema} />

  <section class="conditions-hero">
    <img class="conditions-hero__bg" src="/images/val6.jpg" alt="Paraglider flying over the volcanic terrain at El Penon" width="1920" height="1280" loading="eager" />
    <div class="conditions-hero__overlay"></div>
    <div class="conditions-hero__content">
      <p class="eyebrow">Weather and season reference</p>
      <h1>Valle de Bravo Paragliding Conditions</h1>
      <p>Live town weather, a 7-day forecast, and a month-by-month read on what flying actually looks like here. Updated by Damien from 25+ years of flying El Penon.</p>
    </div>
  </section>

  <Breadcrumbs items={breadcrumbs} />

  <div class="container author-wrap">
    <div class="author-card">
      <img src="/images/damion.jpg" alt="Damien Mitchell" width="56" height="56" class="author-card__avatar" />
      <div class="author-card__info">
        <a href="/about-us/" class="author-card__name">Damien Mitchell</a>
        <span class="author-card__title">USHPA Advanced Instructor</span>
      </div>
    </div>
  </div>

  <section class="section section--white current-conditions" aria-labelledby="current-conditions-heading">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Live weather</p>
        <h2 id="current-conditions-heading">Current Conditions</h2>
        <p>Live weather pulled from Open-Meteo for Valle de Bravo town (19.1838, -100.1278). Town-level current conditions, hourly outlook, and a 7-day forecast for trip planning. For launch-level wind, the Holfuy station and Windguru launch forecast linked below are what we actually check before going up.</p>
      </div>

      <div class="weather-toolbar">
        <div>
          <p class="weather-toolbar__label">Live town weather</p>
          <p class="weather-toolbar__meta">Valle de Bravo local time. Open-Meteo model data.</p>
        </div>
        <div class="unit-toggle" role="group" aria-label="Weather units">
          <button type="button" class="is-active" data-unit-system="us" aria-pressed="true">F / mph</button>
          <button type="button" data-unit-system="metric" aria-pressed="false">C / km/h</button>
        </div>
      </div>

      <div class="source-grid" aria-label="Weather data sources">
        <a class="source-card source-card--launch" href="https://holfuy.com/en/weather/609" target="_blank" rel="noopener noreferrer">
          <span>Launch station</span>
          <strong>Holfuy El Peñón Launch</strong>
          <em>Live station at about 2,350m AMSL</em>
        </a>
        <a class="source-card" href="https://www.windguru.cz/766336" target="_blank" rel="noopener noreferrer">
          <span>Launch forecast</span>
          <strong>Windguru El Peñón Takeoff</strong>
          <em>Spot forecast for the launch area</em>
        </a>
        <a class="source-card" href="https://open-meteo.com/" target="_blank" rel="noopener noreferrer">
          <span>Town model</span>
          <strong>Open-Meteo Valle de Bravo</strong>
          <em>Used below for the meteogram and forecast</em>
        </a>
      </div>

      <div class="graph-source-note">
        <strong>Graph data source:</strong> The custom meteogram below uses Open-Meteo model data for Valle de Bravo town coordinates. For launch-level wind, the live Holfuy widget below is the actual reading at the El Peñón Launch station. For a launch-area forecast, check <a href="https://www.windguru.cz/766336" target="_blank" rel="noopener noreferrer">Windguru El Peñón Takeoff</a>.
      </div>

      <div class="holfuy-panel" data-holfuy-panel>
        <div class="holfuy-panel__header">
          <div>
            <p class="weather-toolbar__label">Live launch wind &amp; webcam</p>
            <h3>Holfuy El Peñón Launch <span class="holfuy-panel__elevation">~2,350m AMSL</span></h3>
            <p class="holfuy-panel__meta">Live sensor reading and webcam from the launch itself. This is what we check before going up.</p>
          </div>
          <div class="holfuy-panel__actions">
            <span class="holfuy-panel__freshness" data-holfuy-freshness>Loading live data...</span>
            <a href="https://holfuy.com/en/weather/609" target="_blank" rel="noopener noreferrer" class="holfuy-panel__link">Open on Holfuy</a>
            <a href="https://holfuy.com/en/camera/609" target="_blank" rel="noopener noreferrer" class="holfuy-panel__link holfuy-panel__link--secondary">Camera history</a>
          </div>
        </div>

        <div class="holfuy-camera">
          <figure class="holfuy-camera__frame">
            <img
              data-holfuy-camera
              src="https://api.holfuy.com/cam/s609.jpg"
              alt="Live webcam view from El Peñón Launch in Valle de Bravo"
              width="1280"
              height="720"
              loading="lazy"
              referrerpolicy="no-referrer"
              onerror="this.closest('.holfuy-camera').setAttribute('hidden','');"
            />
            <figcaption class="holfuy-camera__caption">
              <span>Webcam at the launch ramp</span>
              <span data-holfuy-camera-updated>updating...</span>
            </figcaption>
          </figure>
        </div>

        <div class="holfuy-data" data-holfuy-data hidden>
          <div class="holfuy-data__hero">
            <div class="holfuy-compass" aria-hidden="true">
              <svg viewBox="0 0 120 120" class="holfuy-compass__svg">
                <circle cx="60" cy="60" r="54" class="holfuy-compass__ring" />
                <text x="60" y="14" class="holfuy-compass__cardinal">N</text>
                <text x="60" y="114" class="holfuy-compass__cardinal">S</text>
                <text x="10" y="64" class="holfuy-compass__cardinal">W</text>
                <text x="110" y="64" class="holfuy-compass__cardinal">E</text>
                <g class="holfuy-compass__arrow" data-holfuy-compass-arrow>
                  <path d="M60 18 L52 54 L60 48 L68 54 Z" />
                </g>
                <circle cx="60" cy="60" r="6" class="holfuy-compass__hub" />
              </svg>
              <span class="holfuy-compass__label" data-holfuy-dir>--</span>
            </div>

            <div class="holfuy-readout">
              <p class="holfuy-readout__label">Wind now</p>
              <p class="holfuy-readout__value">
                <span data-holfuy-speed>--</span><span class="holfuy-readout__unit">mph</span>
                <span class="holfuy-readout__gust">gust <strong data-holfuy-gust>--</strong></span>
              </p>
              <p class="holfuy-readout__direction">
                Direction <strong data-holfuy-dir-text>--</strong>
              </p>
              <div class="holfuy-trend" data-holfuy-trend hidden>
                <div class="holfuy-trend__item">
                  <span>Trend</span>
                  <strong data-holfuy-trend-summary>--</strong>
                </div>
                <div class="holfuy-trend__sparkline" data-holfuy-sparkline aria-label="Recent wind speed sparkline"></div>
              </div>

              <div class="holfuy-readout__avgs">
                <div>
                  <span>15-min avg</span>
                  <strong><span data-holfuy-avg-speed>--</span> mph <span data-holfuy-avg-dir>--</span></strong>
                </div>
                <div>
                  <span>15-min peak gust</span>
                  <strong><span data-holfuy-avg-gust>--</span> mph</strong>
                </div>
                <div>
                  <span>Daily avg / max gust</span>
                  <strong><span data-holfuy-daily-avg>--</span> / <span data-holfuy-daily-max>--</span> mph</strong>
                </div>
              </div>
            </div>
          </div>

          <div class="holfuy-metrics">
            <div class="holfuy-metric">
              <span>Air temp</span>
              <strong><span data-holfuy-temp>--</span>F</strong>
              <span class="holfuy-metric__sub">High <span data-holfuy-temp-max>--</span> / Low <span data-holfuy-temp-min>--</span></span>
            </div>
            <div class="holfuy-metric">
              <span>Humidity</span>
              <strong><span data-holfuy-humidity>--</span>%</strong>
            </div>
            <div class="holfuy-metric holfuy-metric--cloudbase">
              <span>Cloud base</span>
              <strong><span data-holfuy-cloudbase>--</span>m AMSL</strong>
              <span class="holfuy-metric__sub" data-holfuy-cloudbase-launch>--</span>
            </div>
            <div class="holfuy-metric">
              <span>Pressure</span>
              <strong><span data-holfuy-pressure>--</span> hPa</strong>
            </div>
            <div class="holfuy-metric">
              <span>Rain today</span>
              <strong><span data-holfuy-rain>--</span> mm</strong>
            </div>
          </div>

          <p class="holfuy-attribution">
            Live sensor data via <a href="https://holfuy.com/en/weather/609" target="_blank" rel="noopener noreferrer">Holfuy El Peñón Launch (station 609)</a>. Refreshes when the page loads. Independent local pilots own and maintain the station.
          </p>
        </div>

        <div class="holfuy-fallback" data-holfuy-fallback hidden>
          <p class="holfuy-fallback__note">Could not load the parsed live feed - showing the original Holfuy widget instead.</p>
          <iframe
            title="Holfuy El Peñón Launch live readings"
            src="https://widget.holfuy.com/?station=609&su=mph&t=F&lang=en&type=2"
            frameborder="0"
            scrolling="no"
            loading="lazy"
            class="holfuy-frame"
          ></iframe>
        </div>
      </div>

      <div class="weather-widget" data-weather-widget>
        <div class="weather-dashboard">
          <div class="weather-card weather-card--primary" data-weather-card>
            <div class="weather-card__header">
              <div>
                <p class="weather-card__label">Valle de Bravo town</p>
                <h3>Right Now</h3>
              </div>
              <span class="weather-card__status" data-weather-status>Loading weather...</span>
            </div>
            <div class="weather-card__body" data-current-weather>
              <div class="weather-placeholder">Fetching current temperature, wind, humidity, and cloud cover.</div>
            </div>
          </div>

          <div class="planning-card" data-planning-card>
            <div class="weather-placeholder">Loading today's planning snapshot.</div>
          </div>
        </div>

        <div class="meteogram-panel">
          <div class="forecast-panel__header">
            <div>
              <h3>5-Day Meteogram</h3>
              <p>Hourly temperature, cloud cover, precipitation, wind speed, gusts, and wind direction.</p>
            </div>
            <div class="meteogram-links" aria-label="Launch wind source links">
              <a href="https://holfuy.com/en/weather/609" target="_blank" rel="noopener noreferrer">Holfuy launch wind</a>
              <a href="https://www.windguru.cz/766336" target="_blank" rel="noopener noreferrer">Windguru launch forecast</a>
            </div>
          </div>
          <div class="meteogram-frame" data-meteogram aria-live="polite">
            <div class="forecast-loading">Loading meteogram...</div>
          </div>
        </div>

        <div class="hourly-panel">
          <div class="forecast-panel__header">
            <div>
              <h3>Next 12 Hours</h3>
              <p>Town-level trend for wind, precipitation probability, and cloud cover.</p>
            </div>
          </div>
          <div class="hourly-strip" data-hourly-strip aria-live="polite">
            <div class="forecast-loading">Loading hourly outlook...</div>
          </div>
        </div>

        <div class="forecast-panel">
          <div class="forecast-panel__header">
            <div>
              <h3>7-Day Forecast With Flyability Score</h3>
              <p>A 0-5 paragliding flyability score per day, weighted by max wind, gust, cloud cover, and precip probability. Green border = good or better. Trust day 1-3 most; day 5-7 is indicative.</p>
            </div>
          </div>
          <div class="forecast-strip" data-forecast-strip aria-live="polite">
            <div class="forecast-loading">Loading forecast...</div>
          </div>
        </div>
      </div>

      <p class="weather-disclaimer">This is general weather data for Valle de Bravo town. Flying conditions at El Penon launch (7,600 ft) differ from town level (5,000 ft). Wind, temperature, and cloud patterns change significantly with altitude. Always consult with your instructor for current flying conditions. This data is for trip planning reference only, not flight decision-making.</p>
    </div>
  </section>

  <section class="section section--cream monthly-reference" aria-labelledby="monthly-reference-heading">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Season reference</p>
        <h2 id="monthly-reference-heading">Month-by-Month Conditions</h2>
        <p>What a typical day looks like in each month, based on 25+ years of flying El Penon. Tap a month for the detail. The five peak months also have their own dedicated guide pages with deeper write-ups.</p>
      </div>

      <div class="month-grid">
        {monthlyConditions.map((condition) => (
          <details class="month-card" data-season={condition.season.toLowerCase()}>
            <summary>
              <span class="month-card__summary-main">
                <span class="month-card__name">{condition.name}</span>
                <span class="season-tag">{condition.season}</span>
              </span>
              <span class="rating-meter" aria-label={`Flyability rating ${condition.ratingLabel}`}>
                <span class="rating-meter__track">
                  <span class="rating-meter__fill" style={`width: ${condition.ratingPercent}`}></span>
                </span>
                <span class="rating-meter__label">{condition.ratingLabel}</span>
              </span>
            </summary>

            <div class="month-card__details">
              <dl>
                <div>
                  <dt>Temperature</dt>
                  <dd>{condition.temp}</dd>
                </div>
                <div>
                  <dt>Thermals</dt>
                  <dd>{condition.thermals}</dd>
                </div>
                <div>
                  <dt>Cloudbase</dt>
                  <dd>{condition.cloudbase}</dd>
                </div>
                <div>
                  <dt>Flying window</dt>
                  <dd>{condition.window}</dd>
                </div>
                <div>
                  <dt>Precipitation</dt>
                  <dd>{condition.rain}</dd>
                </div>
                <div>
                  <dt>Crowds</dt>
                  <dd>{condition.crowds}</dd>
                </div>
                <div>
                  <dt>XC potential</dt>
                  <dd>{condition.xc}</dd>
                </div>
              </dl>
              <p>{condition.recommendation}</p>
              <div class="month-card__actions">
                {condition.guideUrl && (
                  <a href={condition.guideUrl} class="month-card__guide-link">Read the full {condition.name} guide</a>
                )}
                <a href="/tours/10-day-paraglide-mexico-package/" class="btn btn--primary">Book a {condition.name} trip</a>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--cream which-month-section" aria-labelledby="which-month-heading">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Decision matrix</p>
        <h2 id="which-month-heading">Which Month Should You Come?</h2>
        <p>If you have not already picked dates, here is how I think about it.</p>
      </div>

      <div class="decision-grid">
        <div class="decision-card">
          <h3>First international flying trip</h3>
          <p><strong>November.</strong> The cleanest air of the season, mid-strength thermals, comfortable temperatures, and crowds are still moderate. Pair it with a <a href="/paragliding-clinics-mexico/paragliding-thermalling-clinic-mexico/">thermalling clinic</a> for the fastest skill jump.</p>
        </div>
        <div class="decision-card">
          <h3>Pushing XC distance</h3>
          <p><strong>December or early January.</strong> Highest cloudbase and strongest thermal streets of the year. Pair with our <a href="/paragliding-clinics-mexico/mexico-cross-country-xc-paragliding-clinics/">XC clinic</a>. Read more in <a href="/intro-to-cross-country-paragliding/">our intro to cross-country flying</a>.</p>
        </div>
        <div class="decision-card">
          <h3>P2 pilot working toward P3</h3>
          <p>Any peak month works. February offers the best combination of reliable conditions and small groups. See our <a href="/valle-de-bravo-p2-pilots/">guide for P2 pilots</a> and the <a href="/p2-to-p3-paragliding-progression/">P2-to-P3 progression</a>.</p>
        </div>
        <div class="decision-card">
          <h3>Best value (peak conditions, less crowd)</h3>
          <p><strong>January or February.</strong> December-quality flying with a fraction of the holiday-period chaos. Bring layers - mornings are the coolest of the season.</p>
        </div>
        <div class="decision-card">
          <h3>Combining with a partner who is not flying</h3>
          <p>Any peak month. Valle is a charming colonial town. See our <a href="/valle-de-bravo-travel-guide-paragliders/">travel guide for paragliders</a> for what they can do on rest days.</p>
        </div>
        <div class="decision-card">
          <h3>Avoid</h3>
          <p>May through September is rainy season. Mornings can be flyable but afternoon storms shut things down. We do not run guided trips during these months. <a href="/best-winter-paragliding-destinations/">Look at Brazil instead</a> if you need that window.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--white conditions-links" aria-labelledby="conditions-links-heading">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Related reading</p>
