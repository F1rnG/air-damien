---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Blog - Air Damien Paragliding"
  description="Paragliding tips, stories, and insights from Air Damien. Learn about thermalling, cross-country flying, and life in Valle de Bravo."
>
  <section class="page-header">
    <h1>Blog</h1>
  </section>

  <section class="section section--white">
    <div class="container text-center">
      <div class="blog-placeholder animate-in">
        <h2>Coming Soon</h2>
        <p>We are working on bringing you the latest paragliding tips, stories, and insights. Check back soon for new posts.</p>
        <div class="blog-posts-preview">
          <h3>Recent Posts</h3>
          <ul>
            <li><a href="/best-months-to-paraglide-mexico/">The Best Months for Paragliding in Valle de Bravo, Mexico</a></li>
            <li><a href="/intro-to-cross-country-paragliding/">An Introduction to Cross-Country Paragliding</a></li>
            <li><a href="/thermal-in-paragliding-techniques-and-tips/">The Art of Thermal in Paragliding</a></li>
            <li><a href="/can-i-paraglide-anywhere/">Can I paraglide anywhere?</a></li>
            <li><a href="/how-to-land-a-paraglider/">How to land a paraglider?</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-placeholder {
    max-width: 600px;
    margin: 0 auto;
  }

  .blog-placeholder h2 {
    margin-bottom: 1rem;
  }

  .blog-posts-preview {
    margin-top: 3rem;
    text-align: left;
    background: var(--color-cream);
    border-radius: 12px;
    padding: 2rem;
  }

  .blog-posts-preview h3 {
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  .blog-posts-preview ul {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .blog-posts-preview a {
    font-size: 1rem;
  }
</style>
