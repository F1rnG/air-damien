---

<BaseLayout
  title="Blog - Paraglide Mexico | Paraglide Utah"
  description="Informative paragliding blogs and articles, written by an USHPA Advanced Instructor, to help to you advance your paragliding skills. A must read!"
  canonicalUrl="https://airdamien.com/blog/"
>
  <div class="page-header">
    <div class="container">
      <h1>Blog</h1>
    </div>
  </div>

  <Breadcrumbs items={breadcrumbs} />

  <!-- Featured CTA Banner -->
  <section class="blog-cta-banner">
    <div class="container">
      <p>Looking to put your skills to the test? <a href="/paragliding-clinics-mexico/" class="btn btn--primary btn--sm">Fly with us in Valle de Bravo</a></p>
    </div>
  </section>

  <!-- Destination Guides (pinned) -->
  <section class="section">
    <div class="container">
      <div class="section__heading">
        <h2>Destination Guides</h2>
      </div>
      <div class="blog-grid">
        {guides.map(guide => (
          <BlogCard
            title={guide.title}
            url={guide.url}
            description={guide.description}
            date={guide.date}
            readingTime={guide.readingTime}
            image={guide.image}
            imageAlt={guide.imageAlt}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- All Posts -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__heading">
        <h2>All Articles</h2>
      </div>
      <div class="blog-grid">
        {posts.map(post => (
          <BlogCard
            title={post.title}
            url={post.url}
            description={post.description}
            date={post.date}
            readingTime={post.readingTime}
            image={post.image}
            imageAlt={post.imageAlt}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-cta-banner {
    background: var(--color-primary, #4a4168);
    color: #fff;
    padding: 1rem 0;
    text-align: center;
  }

  .blog-cta-banner p {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin: 0;
    font-size: 1.05rem;
  }

  .btn--sm {
    padding: 0.5rem 1.25rem;
    font-size: 0.85rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 480px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
