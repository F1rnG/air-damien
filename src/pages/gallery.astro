---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

const gallerySchema = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  "name": "Air Damien Photo Gallery",
  "url": "https://airdamien.com/gallery/",
  "description": "Paragliding photos from Valle de Bravo, Mexico and Utah"
};
---

<BaseLayout
  title="Gallery - Paraglide Mexico | Paraglide Utah"
  description='Paragliding photos from Valle de Bravo and Point of the Mountain (POTM), Utah. See the best of "Sky Life". Get to see the views pilots see every day.'
  canonicalUrl="https://airdamien.com/gallery/"
>
  <SchemaMarkup schema={gallerySchema} />
  <section class="page-header">
    <h1>Gallery</h1>
  </section>
  <Breadcrumbs items={[
    { name: "Home", url: "https://airdamien.com/" },
    { name: "Gallery", url: "https://airdamien.com/gallery/" }
  ]} />

  <section class="section section--white">
    <div class="container">
      <GalleryGrid title="A taste of Sky Life in El Penon" count={24} />
      <GalleryGrid title="A taste of Valle de Bravo" count={14} />
      <GalleryGrid title="A taste of Sky Life in the Wasatch Mountains" count={12} />
      <GalleryGrid title="A taste of Salt Lake City" count={13} />

      <div class="gallery-social animate-in text-center">
        <p>Would you like to share a photo? Follow us on <a href="https://www.instagram.com/air.damien/" target="_blank" rel="noopener noreferrer">Instagram @Air.Damien</a> or <a href="https://www.facebook.com/groups/1084131562402201/" target="_blank" rel="noopener noreferrer">Facebook @airdamien</a></p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .gallery-social {
    margin-top: 2rem;
    padding: 2rem;
    background: var(--color-cream);
    border-radius: 12px;
  }

  .gallery-social p {
    font-size: 1.1rem;
    margin: 0;
  }
</style>
