---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeamCard from '../components/TeamCard.astro';
import ContactForm from '../components/ContactForm.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Air Damien",
  "url": "https://airdamien.com",
  "founder": {
    "@type": "Person",
    "name": "Damien Mitchell",
    "jobTitle": "USHPA Advanced Instructor"
  },
  "employee": [
    {
      "@type": "Person",
      "name": "Damien Mitchell",
      "jobTitle": "Advanced Instructor"
    },
    {
      "@type": "Person",
      "name": "Alondra Mejia",
      "jobTitle": "Booking Manager"
    },
    {
      "@type": "Person",
      "name": "Carlos El Conductor",
      "jobTitle": "Driver and Launch Assistant"
    }
  ]
};
---

<BaseLayout
  title="About Us - Paraglide Mexico | Paraglide Utah"
  description="I'm Damien, they call me Vampiro. I teach paragliding to at El Penon in Valle de Bravo, Mexico and at The Point of the Mountain in Utah."
  canonicalUrl="https://airdamien.com/about-us/"
>
  <SchemaMarkup schema={organizationSchema} />

  <!-- Hero -->
  <section class="page-header">
    <h1>About Us</h1>
  </section>

  <Breadcrumbs items={[{ name: "Home", url: "https://airdamien.com/" }, { name: "About Us", url: "https://airdamien.com/about-us/" }]} />

  <!-- Photo Grid -->
  <section class="section section--white">
    <div class="container">
      <div class="about-photos grid-3 animate-in">
        <div class="card__image"><img src="/images/Damion2.jpg" alt="Damien Mitchell preparing for a paragliding flight" width="800" height="600" loading="lazy" /></div>
        <div class="card__image"><img src="/images/Damion5.jpg" alt="Paragliding over Valle de Bravo mountains" width="800" height="600" loading="lazy" /></div>
        <div class="card__image"><img src="/images/coaching 1.jpg" alt="Damien coaching a pilot at the landing zone" width="800" height="600" loading="lazy" /></div>
        <div class="card__image"><img src="/images/gaggle.jpg" alt="Gaggle of paragliders thermalling over El Penon" width="1024" height="683" loading="lazy" /></div>
        <div class="card__image"><img src="/images/valle 1.jpg" alt="Valle de Bravo lakeside town and mountains" width="800" height="450" loading="lazy" /></div>
        <div class="card__image"><img src="/images/cross.jpg" alt="Hiking the volcanic ridge near Valle de Bravo" width="800" height="800" loading="lazy" /></div>
      </div>
    </div>
  </section>

  <!-- Our Story -->
  <section class="section section--cream">
    <div class="container">
      <div class="about-story animate-in">
        <h2>Our Story</h2>
        <p>People call me Vampiro. Only a few people know the story behind the nickname.</p>
        <p>About 10-years ago, I landed out on the top of Crazy Thermal Mesa. I was faced with a three-mile hike to the nearest road with 40 pounds of gear. I came across a young boy. He offered to carry some of my gear to make some extra money.</p>
        <p>On the hike out we got about a mile. And wham, he was bitten by a rattlesnake.</p>
        <p>With few options, I applied a tourniquet to his leg, then began sucking the venom out of his wound. It was a bush fix, but it bought us enough time to get him to the hospital.</p>
        <p>He was ok, but the legend began. The kids still tell the story of Vampiro, a man flies out of the sky and saves young children.</p>
        <p>And so the name stuck.</p>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="section section--sky text-center">
    <div class="container animate-in">
      <h2>Our Mission</h2>
      <p class="mission-text">Learn to fly safe. Leave with a smile.</p>
    </div>
  </section>

  <!-- Team -->
  <section class="section section--white">
    <div class="container">
      <div class="section__heading animate-in">
        <h2>Meet the Team</h2>
      </div>
      <div class="grid-3 animate-in">
        <TeamCard
          name="Damien Mitchell"
          role="Advanced Instructor"
          bio="Damien will be your 'Instructor-in-your-ear' as you launch, climb out, and land."
          image="/images/damien 1.jpg"
          imageAlt="Damien Mitchell coaching a student at launch"
        />
        <TeamCard
          name="Alondra Mejia"
          role="Booking Manager"
          bio="Alondra will help coordinate your session and organize all the details. She is bi-lingual and aid you in any translation needs."
          image="/images/alondra.jpg"
          imageAlt="Alondra Mejia, Booking Manager"
        />
        <TeamCard
          name="Carlos El Conductor"
          role="Driver and Launch Assistant"
          bio="Carlos does all the heavy lifting - he drives, loads, and unloads gear. He also swears in two languages."
          image="/images/carlos.jpg"
          imageAlt="Carlos El Conductor, Driver and Launch Assistant"
        />
      </div>
    </div>
  </section>

  <!-- Careers -->
  <section class="section section--cream">
    <div class="container">
      <div class="section__heading animate-in">
        <h2>Careers With Us</h2>
        <p>We are a growing team and need full and part-time help to keep up with the demand.</p>
      </div>
      <div class="grid-2 animate-in">
        <div class="card">
          <div class="card__body">
            <h4>Shuttle Drivers</h4>
            <p>We work 7-days a week and are always looking for drivers. Full-time and part-time.</p>
          </div>
        </div>
        <div class="card">
          <div class="card__body">
            <h4>Tour Guides</h4>
            <p>We need English speaking tour guides who are familiar with all the signature tourist destinations in Valle de Bravo.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section section--white">
    <div class="container">
      <div class="section__heading animate-in">
        <h3>Contact Us</h3>
      </div>
      <div class="animate-in">
        <ContactForm formName="about-contact" showPhone={false} messageLabel="Question / Comment" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-photos .card__image {
    border-radius: 8px;
    min-height: 200px;
  }

  .about-story {
    max-width: 800px;
    margin: 0 auto;
  }

  .about-story h2 {
    margin-bottom: 1.5rem;
  }

  .about-story p {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .mission-text {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 1rem;
  }
</style>
