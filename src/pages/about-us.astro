---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeamCard from '../components/TeamCard.astro';
import ContactForm from '../components/ContactForm.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import StatsBar from '../components/StatsBar.astro';
import TestimonialCard from '../components/TestimonialCard.astro';

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Air Damien",
  "url": "https://airdamien.com",
  "founder": {
    "@type": "Person",
    "name": "Damien Mitchell",
    "jobTitle": "USHPA Advanced Instructor"
  },
  "employee": [
    {
      "@type": "Person",
      "name": "Damien Mitchell",
      "jobTitle": "Advanced Instructor"
    },
    {
      "@type": "Person",
      "name": "Alondra Mejia",
      "jobTitle": "Booking Manager"
    },
    {
      "@type": "Person",
      "name": "Carlos El Conductor",
      "jobTitle": "Driver and Launch Assistant"
    }
  ]
};
---

<BaseLayout
  title="About Us - Paraglide Mexico | Paraglide Utah"
  description="I'm Damien, they call me Vampiro. I teach paragliding to at El Penon in Valle de Bravo, Mexico and at The Point of the Mountain in Utah."
  canonicalUrl="https://airdamien.com/about-us/"
>
  <SchemaMarkup schema={organizationSchema} />

  <section class="page-header">
    <h1>About Us</h1>
  </section>

  <Breadcrumbs items={[{ name: "Home", url: "https://airdamien.com/" }, { name: "About Us", url: "https://airdamien.com/about-us/" }]} />

  <!-- Meet Damien -->
  <section class="section">
    <div class="container">
      <div class="about-hero animate-in">
        <div class="about-hero__image">
          <img src="/images/Damion3.jpg" alt="Damien Mitchell paragliding over the green mountains of Valle de Bravo" width="600" height="600" loading="eager" />
        </div>
        <div class="about-hero__text">
          <h2>Meet Damien "Vampiro" Mitchell</h2>
          <p class="about-hero__hook">People call me Vampiro.</p>
          <p>Only a few people know the story behind the nickname.</p>
          <p>About 10 years ago, I landed out on the top of Crazy Thermal Mesa. I was faced with a three-mile hike to the nearest road with 40 pounds of gear. I came across a young boy. He offered to carry some of my gear to make some extra money.</p>
          <p>On the hike out we got about a mile. And wham, he was bitten by a rattlesnake.</p>
          <p>With few options, I applied a tourniquet to his leg, then began sucking the venom out of his wound. It was a bush fix, but it bought us enough time to get him to the hospital.</p>
          <p>He was ok, but the legend began. The kids still tell the story of Vampiro, a man who flies out of the sky and saves young children.</p>
          <p>And so the name stuck.</p>
          <p>Read Damien's flying insights, site reports, and trip writeups on <a href="/blog/">our blog</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <StatsBar />

  <!-- Mission -->
  <section class="section section--purple text-center">
    <div class="container animate-in">
      <h2>Our Mission</h2>
      <p class="mission-text">Learn to fly safe. Leave with a smile.</p>
    </div>
  </section>

  <!-- Photo Gallery Strip -->
  <section class="section section--alt">
    <div class="container">
      <p class="gallery-strip__label animate-in">Life at El Penon</p>
      <div class="gallery-strip animate-in">
        <div class="gallery-strip__item"><img src="/images/gaggle.jpg" alt="Gaggle of paragliders thermalling over El Penon" width="800" height="600" loading="lazy" /></div>
        <div class="gallery-strip__item"><img src="/images/coaching 1.jpg" alt="Damien coaching a pilot at the landing zone" width="800" height="600" loading="lazy" /></div>
        <div class="gallery-strip__item"><img src="/images/Damion5.jpg" alt="Paragliding over Valle de Bravo mountains" width="800" height="600" loading="lazy" /></div>
        <div class="gallery-strip__item"><img src="/images/valle 1.jpg" alt="Valle de Bravo lakeside town and mountains" width="800" height="450" loading="lazy" /></div>
        <div class="gallery-strip__item"><img src="/images/sitting 1.jpg" alt="Pilots relaxing after a day of flying" width="800" height="600" loading="lazy" /></div>
        <div class="gallery-strip__item"><img src="/images/cross.jpg" alt="Hiking the volcanic ridge near Valle de Bravo" width="800" height="800" loading="lazy" /></div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section">
    <div class="container">
      <div class="section__heading animate-in">
        <h2>Meet the Team</h2>
      </div>
      <div class="grid-3 animate-in">
        <TeamCard
          name="Damien Mitchell"
          role="Advanced Instructor"
          bio="Damien will be your 'Instructor-in-your-ear' as you launch, climb out, and land."
          image="/images/damion.jpg"
          imageAlt="Damien Mitchell, USHPA Advanced Instructor"
        />
        <TeamCard
          name="Alondra Mejia"
          role="Booking Manager"
          bio="Alondra will help coordinate your session and organize all the details. She is bi-lingual and aid you in any translation needs."
          image="/images/alondra.jpg"
          imageAlt="Alondra Mejia, Booking Manager"
        />
        <TeamCard
          name="Carlos El Conductor"
          role="Driver and Launch Assistant"
          bio="Carlos does all the heavy lifting - he drives, loads, and unloads gear. He also swears in two languages."
          image="/images/carlos.jpg"
          imageAlt="Carlos El Conductor, Driver and Launch Assistant"
        />
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section section--alt">
    <div class="container text-center">
      <div class="about-cta animate-in">
        <h2>Ready to Fly with Us?</h2>
        <p>Whether you're looking to master thermalling or go on your first cross-country flight, we'll build a trip around your skill level and schedule.</p>
        <div class="about-cta__buttons">
          <a href="/paragliding-clinics-mexico/" class="btn btn--primary">View Our Clinics</a>
          <a href="/contact/" class="btn btn--secondary">Contact Damien</a>
        </div>
      </div>
      <div class="about-cta__testimonial animate-in">
        <TestimonialCard
          quote="For many years Damien has been an invaluable source of knowledge and wisdom regarding everything paragliding and an absolute mainstay to our trips to Valle de Bravo. He really knows the place like no other."
          author="Bianca Heinrich"
          role="Comp Pilot"
        />
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section">
    <div class="container">
      <div class="section__heading animate-in">
        <h2>Have Questions? Reach Out.</h2>
      </div>
      <div class="animate-in">
        <ContactForm formName="about-contact" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Meet Damien two-column */
  .about-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .about-hero {
      grid-template-columns: 1fr 1.2fr;
    }
  }

  .about-hero__image img {
    width: 100%;
    height: auto;
    min-height: 400px;
    object-fit: cover;
    border-radius: 12px;
  }

  .about-hero__text h2 {
    margin-bottom: 1.5rem;
  }

  .about-hero__hook {
    font-size: 1.5rem;
    font-weight: 500;
    font-family: var(--font-display);
    color: var(--color-text);
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  .about-hero__text p {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  /* Mission */
  .mission-text {
    font-size: 1.5rem;
    font-weight: 500;
    margin-top: 1rem;
    color: var(--color-text-on-dark);
  }

  /* Gallery strip */
  .gallery-strip__label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-muted);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .gallery-strip {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.75rem;
  }

  .gallery-strip__item {
    aspect-ratio: 1 / 1;
    border-radius: 8px;
    overflow: hidden;
  }

  .gallery-strip__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .gallery-strip__item:hover img {
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .gallery-strip {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 480px) {
    .gallery-strip {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* CTA section */
  .about-cta p {
    max-width: 600px;
    margin: 0 auto 2rem;
    color: var(--color-text-body);
  }

  .about-cta__buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .about-cta__testimonial {
    max-width: 650px;
    margin: 0 auto;
  }
</style>
