---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import StatsBar from '../components/StatsBar.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://airdamien.com/#business",
    "name": "Air Damien",
    "description": "Paragliding instruction and guided tours in Valle de Bravo, Mexico and Draper, Utah",
    "url": "https://airdamien.com",
    "telephone": "+18012444791",
    "email": "Damien@AirDamien.com",
    "image": "https://airdamien.com/images/logo.png",
    "priceRange": "$$",
    "address": [
      {
        "@type": "PostalAddress",
        "streetAddress": "Marina Nacional 202, Sin Nombre",
        "addressLocality": "Valle de Bravo",
        "addressRegion": "State of Mexico",
        "addressCountry": "MX"
      },
      {
        "@type": "PostalAddress",
        "streetAddress": "121100 N East, N Frontage Road",
        "addressLocality": "Draper",
        "addressRegion": "UT",
        "postalCode": "84020",
        "addressCountry": "US"
      }
    ],
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 19.183792,
      "longitude": -100.127785
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "33",
      "bestRating": "5",
      "worstRating": "1"
    },
    "founder": {
      "@type": "Person",
      "name": "Damien Mitchell",
      "jobTitle": "USHPA Advanced Instructor"
    },
    "sameAs": [
      "https://www.facebook.com/groups/1084131562402201/",
      "https://www.youtube.com/air_damien",
      "https://www.instagram.com/air.damien/",
      "https://twitter.com/AirDamien",
      "https://tiktok.com/@airdamien"
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Paragliding Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Thermalling Clinic",
            "url": "https://airdamien.com/paragliding-clinics-mexico/paragliding-thermalling-clinic-mexico/"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Cross Country (XC) Clinic",
            "url": "https://airdamien.com/paragliding-clinics-mexico/mexico-cross-country-xc-paragliding-clinics/"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "10 Day Paraglide Mexico Package",
            "url": "https://airdamien.com/tour/10-day-paraglide-mexico-package/"
          }
        }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Air Damien",
    "url": "https://airdamien.com",
    "description": "Paragliding instruction in Valle de Bravo, Mexico and Utah"
  }
];
---

<BaseLayout
  title="Home - Paraglide Mexico | Paraglide Utah"
  description="We teach advanced paragliding at in Valle de Bravo, Mexico. Learn how to catch the best thermals in the world. Book your session today!"
  canonicalUrl="https://airdamien.com/"
>
  <SchemaMarkup schema={schema} />

  <h1 class="sr-only">Home</h1>

  <!-- Hero -->
  <section class="hero hero--full">
    <img class="hero__bg" src="/images/Group-2asdf.png" alt="Paraglider soaring over El Penon in Valle de Bravo, Mexico" width="1920" height="1080" loading="eager" />
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title">Paraglide Valle de Bravo with a 25-Year Veteran Instructor</h2>
      <p class="hero__sub">Thermalling clinics, cross-country instruction, and guided flying at Mexico's premier paragliding site. All-inclusive trips with housing, food, and transport.</p>
      <div class="hero__ctas">
        <a href="#book-trip" class="btn btn--primary">Book Your Mexico Trip</a>
        <a href="/paragliding-clinics-mexico/" class="btn btn--outline">View Clinics and Tours</a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <StatsBar />

  <!-- Why Valle de Bravo -->
  <section class="section">
    <div class="container">
      <div class="section__heading animate-in">
        <h2>Why Pilots Choose Valle de Bravo</h2>
      </div>
      <div class="grid-2 grid-2--lg animate-in">
        <div class="feature-card">
          <h3>300+ Flyable Days Per Year</h3>
          <p>El Penon's consistent thermals and predictable conditions mean you fly almost every day.</p>
        </div>
        <div class="feature-card">
          <h3>The Hair Dryer</h3>
          <p>The famous El Penon thermal cycle kicks on at exactly 10am daily. You can set your watch by it.</p>
        </div>
        <div class="feature-card">
          <h3>Ancient Volcano Launch</h3>
          <p>El Penon sits on the ring of an ancient volcano with a friendly launch and oversized landing zone.</p>
        </div>
        <div class="feature-card">
          <h3>Stunning Lakeside Town</h3>
          <p>Valle de Bravo is a charming colonial town on Lake Avandaro. Great food, culture, and nightlife when you're not in the air.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__heading animate-in">
        <h2>Just Show Up and Fly</h2>
        <p>We handle all the logistics so you can focus on what matters - getting better in the air.</p>
      </div>
      <div class="grid-3 animate-in">
        <div class="card">
          <div class="card__image"><img src="/images/Rural-Home-Local-Lane-NBS-750x375-1.jpg" alt="Comfortable housing near the paragliding site in Valle de Bravo" width="750" height="375" loading="lazy" /></div>
          <div class="card__body">
            <h3>Housing and Food</h3>
            <p>Home-cooked meals daily and comfortable accommodations near the flying site. No hunting for restaurants or hotels.</p>
          </div>
        </div>
        <div class="card">
          <div class="card__image"><img src="/images/landing 1.jpg" alt="Paraglider pilot flying over the cliffs of El Penon" width="800" height="600" loading="lazy" /></div>
          <div class="card__body">
            <h3>Guided Instruction</h3>
            <p>Daily guided flights with radio coaching from a USHPA Advanced Instructor. Real-time feedback as you thermal, not just ground school.</p>
          </div>
        </div>
        <div class="card">
          <div class="card__image"><img src="/images/van2.jpg" alt="Air Damien shuttle vehicle for airport and launch transport" width="800" height="450" loading="lazy" /></div>
          <div class="card__body">
            <h3>Transport and Logistics</h3>
            <p>Airport pickup, daily shuttles to launch, and retrieve service for XC flights. Gear spares if you forget something.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Choose Your Clinic -->
  <section class="section">
    <div class="container">
      <div class="section__heading animate-in">
        <h2>Choose Your Clinic</h2>
      </div>
      <div class="grid-2 animate-in">
        <div class="card">
          <div class="card__image"><img src="/images/gaggle.jpg" alt="Gaggle of paragliders thermalling together over Valle de Bravo" width="1024" height="683" loading="lazy" /></div>
          <div class="card__body">
            <h3>Thermalling Clinic (5 Days)</h3>
            <p>Master thermal identification, entry, and efficient climbing. For P2+ pilots ready to extend their flights and gain altitude confidence.</p>
            <a href="/paragliding-clinics-mexico/paragliding-thermalling-clinic-mexico/" class="btn btn--primary">Book Your Thermalling Clinic</a>
          </div>
        </div>
        <div class="card">
          <div class="card__image"><img src="/images/pg 1.jpg" alt="Two paragliders soaring cross-country over Valle de Bravo terrain" width="1024" height="683" loading="lazy" /></div>
          <div class="card__body">
            <h3>Cross Country Clinic</h3>
            <p>Take your flying to the next level with XC route planning, thermal transitions, and long-distance strategy. For intermediate+ pilots.</p>
            <a href="/paragliding-clinics-mexico/mexico-cross-country-xc-paragliding-clinics/" class="btn btn--primary">Book Your XC Clinic</a>
          </div>
        </div>
      </div>
      <p class="text-center" style="margin-top: 1.5rem;">
        Want the full experience? Check out our <a href="/tour/10-day-paraglide-mexico-package/">10 Day Mexico Package</a>.
      </p>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__heading animate-in">
        <h2>What Pilots Say</h2>
      </div>
      <div class="grid-2 animate-in">
        <TestimonialCard
          quote="For many years Damien has been an invaluable source of knowledge and wisdom regarding everything paragliding and an absolute mainstay to our trips to Valle de Bravo. He really knows the place like no other."
          author="Bianca Heinrich"
          role="Comp Pilot"
        />
        <TestimonialCard
          quote="The combination of ground school, launch support, and in-sky coaching provided an incredibly valuable learning experience."
          author="Jim"
          role="Jan 2023"
        />
      </div>
      <div class="grid-2 animate-in" style="margin-top: 1.5rem;">
        <TestimonialCard
          quote="I saw my flying mentality and my piloting skills improve drastically over the course of the week."
          author="Ryan"
          role="Feb 2023"
        />
        <TestimonialCard
          quote="Amazing flying. Great airtime and awesome instruction. The flying was amazing, the weather was perfect, and the company was entertaining."
          author="John Gallagher"
        />
      </div>
      <p class="text-center animate-in" style="margin-top: 1.5rem;">
        <a href="/reviews/" class="form-trust__badge" style="font-size: 1rem;">
          <span style="color: #f5a623;">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span>5.0 stars from 33 reviews</span>
        </a>
      </p>
    </div>
  </section>

  <!-- Meet Your Instructor -->
  <section class="section">
    <div class="container">
      <div class="home-split animate-in">
        <div class="home-split__image">
          <img class="card__image card__image--square" src="/images/Damion3.jpg" alt="Damien Mitchell paragliding over green mountains" width="600" height="600" loading="lazy" style="border-radius: 12px; object-fit: cover; width: 100%; height: auto;" />
        </div>
        <div class="home-split__text">
          <h2>Meet Damien "Vampiro" Mitchell</h2>
          <p>With 25+ years of flying experience and over 10,000 flights, Damien is a USHPA Advanced Instructor who splits his time between the Wasatch Mountains in Utah and El Penon in Valle de Bravo. The locals call him Vampiro - ask him about the rattlesnake story.</p>
          <a href="/about-us/" class="btn btn--secondary">Read Our Full Story</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section section--alt" id="book-trip">
    <div class="container">
      <div class="section__heading animate-in">
        <h2>Ready to Fly Mexico?</h2>
        <p>Tell us when you want to come and we'll build a trip around your schedule and skill level.</p>
      </div>
      <div class="animate-in form-container">
        <ContactForm
          formName="homepage-trip-inquiry"
          messagePlaceholder="I'm interested in the thermalling/XC/10-day clinic. My dates are..."
          buttonText="Book Your Trip"
        />
      </div>
    </div>
  </section>

  <!-- Why El Penon -->
  <section class="section">
    <div class="container">
      <div class="home-content-block animate-in text-center">
        <h3>Relax and Focus on Flying</h3>
        <p>Enjoy a full morning, evening, or day of flying. If you're in town for a week, let's get together and we'll show you all the great launches, all the top LZs and all the best places to get a beer.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 1rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .hero__sub {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    margin-bottom: 2rem;
    opacity: 0.95;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .hero__ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__bg-label {
    color: #fff;
    font-size: 0.9rem;
    opacity: 0.7;
  }

  .feature-card {
    padding: 2rem;
    background: var(--color-bg-off, #f5f5f5);
    border-radius: 8px;
    border-left: 4px solid var(--color-accent, #e8732a);
  }

  .feature-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
    color: var(--color-primary, #4a4168);
  }

  .feature-card p {
    color: var(--color-text-light, #666);
    line-height: 1.6;
  }

  .grid-2--lg {
    gap: 1.5rem;
  }

  .form-container {
    max-width: 600px;
    margin: 0 auto;
  }

  .home-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .home-split {
      grid-template-columns: 1fr 1fr;
    }
  }

  .home-split__image .card__image {
    border-radius: 12px;
    min-height: 350px;
  }

  .card__image--square {
    aspect-ratio: 1 / 1;
  }

  .home-content-block {
    max-width: 800px;
    margin: 0 auto;
  }

  .home-content-block h3 {
    margin-bottom: 1rem;
  }

  .home-content-block p {
    font-size: 1.1rem;
    color: var(--color-text-light, #666);
    line-height: 1.7;
  }

  .form-trust__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text, #333);
    font-weight: 600;
  }
</style>
