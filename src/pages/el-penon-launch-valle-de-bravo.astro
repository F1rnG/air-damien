const mapPoints = [
  {
    name: 'El Penon launch',
    lat: 19.061997,
    lng: -100.090997,
    coords: '19.061997, -100.090997',
    detail: 'Primary Valle de Bravo mountain launch, approximately 7,600 ft / 2,316m ASL.',
    type: 'launch'
  },
  {
    name: 'Piano LZ',
    lat: 19.041882,
    lng: -100.104940,
    coords: '19.041882, -100.104940',
    detail: 'Large landing zone roughly 1.5 miles from launch, named for its piano-key shape.',
    type: 'piano'
