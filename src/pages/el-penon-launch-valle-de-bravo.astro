  {
    src: '/images/val6.jpg',
    alt: 'Paraglider flying above the volcanic ridges near El Penon',
    caption: 'Volcanic ridges and launch area'
  },
  {
    src: '/images/cross.jpg',
    alt: 'The cross above El Penon overlooking Valle de Bravo',
    caption: 'The view from the upper terrain'
  },
  {
    src: '/images/landing 1.jpg',
    alt: 'Pilot landing in Valle de Bravo',
    caption: 'Landing practice in Valle de Bravo'
