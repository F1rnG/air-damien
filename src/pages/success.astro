---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Message Sent - Air Damien"
  description="Your message has been sent successfully."
>
  <div class="page-header">
    <div class="container">
      <h1>Message Sent</h1>
    </div>
  </div>

  <section class="section">
    <div class="container" style="max-width: 600px; margin: 0 auto; text-align: center;">
      <h2>Thank you for reaching out.</h2>
      <p>Damien will get back to you as soon as possible. If you need an immediate response, call <a href="tel:+18012444791">801-244-4791</a>.</p>
      <a href="/" class="btn btn--primary" style="margin-top: 1.5rem;">Back to Home</a>
    </div>
  </section>
</BaseLayout>
