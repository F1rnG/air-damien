---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import reviews from '../data/reviews.json';

const avgRating = (reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length).toFixed(1);
const reviewCount = reviews.length;

const reviewSchemas = reviews.map(r => ({
  "@context": "https://schema.org",
  "@type": "Review",
  "author": { "@type": "Person", "name": r.name },
  "reviewBody": r.body,
  "datePublished": r.date,
  "reviewRating": { "@type": "Rating", "ratingValue": r.rating, "bestRating": 5 },
  "itemReviewed": { "@type": "LocalBusiness", "name": "Air Damien" }
}));

const aggregateSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Air Damien",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": avgRating,
    "reviewCount": String(reviewCount),
    "bestRating": "5",
    "worstRating": "1"
  }
};

const locations = [...new Set(reviews.map(r => r.location))];

const breadcrumbs = [
  { name: "Home", url: "https://airdamien.com/" },
  { name: "Reviews", url: "https://airdamien.com/reviews/" }
];
---

<BaseLayout
  title="Reviews - Paraglide Mexico | Paraglide Utah"
  description="Real, authenticated paragliding reviews from new pilots to competition pilots, from Mexico, to Utah. Add your review now."
  canonicalUrl="https://airdamien.com/reviews/"
>
  <SchemaMarkup schema={aggregateSchema} />
  <SchemaMarkup schema={reviewSchemas} />

  <div class="page-header">
    <div class="container">
      <h1>Reviews</h1>
    </div>
  </div>

  <Breadcrumbs items={breadcrumbs} />

  <section class="section">
    <div class="container">
      <!-- Summary -->
      <div class="reviews-summary animate-in">
        <div class="reviews-summary__stars">
          <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        </div>
        <p class="reviews-summary__rating">{avgRating} out of 5 stars</p>
        <p class="reviews-summary__count">Based on {reviewCount} reviews</p>
        <a href="/add-site-review/" class="btn btn--primary">Write a Review</a>
      </div>

      <!-- Filters -->
      <div class="reviews-filters animate-in">
        <button class="reviews-filter active" data-filter="all">All</button>
        {locations.map(loc => (
          <button class="reviews-filter" data-filter={loc}>{loc}</button>
        ))}
      </div>

      <!-- Reviews Grid -->
      <div class="reviews-grid animate-in">
        {reviews.map(review => (
          <div class="review-card" data-location={review.location}>
            <div class="review-card__header">
              <div class="review-card__stars">
                {Array.from({length: 5}).map((_, i) => (
                  <span class={i < review.rating ? 'star star--filled' : 'star'}>&#9733;</span>
                ))}
              </div>
              <span class="review-card__date">
                {new Date(review.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
            </div>
            <h3 class="review-card__title">{review.title}</h3>
            <p class="review-card__body">{review.body}</p>
            <div class="review-card__footer">
              <span class="review-card__author">{review.name}</span>
              <div class="review-card__badges">
                <span class="review-card__badge review-card__badge--location">{review.location}</span>
                {review.pilotRating && (
                  <span class="review-card__badge review-card__badge--rating">{review.pilotRating}</span>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Pending reviews container (filled by JS) -->
      <div id="pending-reviews"></div>

      <!-- Bottom CTA -->
      <div class="reviews-cta animate-in">
        <h2>Had a great experience? Share it.</h2>
        <a href="/add-site-review/" class="btn btn--primary">Write a Review</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Load pending reviews from localStorage and prepend to grid
  (function() {
    const pending = JSON.parse(localStorage.getItem('pendingReviews') || '[]');
    if (!pending.length) return;

    const grid = document.querySelector('.reviews-grid');
    const starHtml = (rating) => {
      let s = '';
      for (let i = 0; i < 5; i++) {
        s += '<span class="' + (i < rating ? 'star star--filled' : 'star') + '">&#9733;</span>';
      }
      return s;
    };

    pending.forEach(r => {
      const d = new Date(r.date);
      const dateStr = d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
      const card = document.createElement('div');
      card.className = 'review-card review-card--pending';
      card.setAttribute('data-location', r.location);
      card.innerHTML =
        '<div class="review-card__pending-badge">Pending approval</div>' +
        '<div class="review-card__header">' +
          '<div class="review-card__stars">' + starHtml(r.rating) + '</div>' +
          '<span class="review-card__date">' + dateStr + '</span>' +
        '</div>' +
        '<h3 class="review-card__title">' + r.title + '</h3>' +
        '<p class="review-card__body">' + r.body + '</p>' +
        '<div class="review-card__footer">' +
          '<span class="review-card__author">' + r.name + '</span>' +
          '<div class="review-card__badges">' +
            '<span class="review-card__badge review-card__badge--location">' + r.location + '</span>' +
            (r.pilotRating ? '<span class="review-card__badge review-card__badge--rating">' + r.pilotRating + '</span>' : '') +
          '</div>' +
        '</div>';
      grid.insertBefore(card, grid.firstChild);
    });

    // Update count
    const countEl = document.querySelector('.reviews-summary__count');
    if (countEl) {
      const base = parseInt(countEl.textContent.match(/\d+/)[0]);
      countEl.textContent = 'Based on ' + (base + pending.length) + ' reviews';
    }
  })();
</script>

<script>
  document.querySelectorAll('.reviews-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.reviews-filter').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.getAttribute('data-filter');
      document.querySelectorAll('.review-card').forEach(card => {
        if (filter === 'all' || card.getAttribute('data-location') === filter) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .reviews-summary {
    text-align: center;
    margin-bottom: 3rem;
  }

  .reviews-summary__stars {
    font-size: 2rem;
    color: #f5a623;
    margin-bottom: 0.5rem;
  }

  .reviews-summary__rating {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text, #2a2050);
    margin-bottom: 0.25rem;
  }

  .reviews-summary__count {
    color: var(--color-text-body, #5a5570);
    margin-bottom: 1.5rem;
  }

  .reviews-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  .reviews-filter {
    background: var(--color-bg-warm, #f9f7f3);
    border: 1.5px solid var(--color-border, #d8d4e0);
    color: var(--color-text-body, #5a5570);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 150ms ease;
    font-family: inherit;
  }

  .reviews-filter:hover {
    border-color: var(--color-accent, #e07730);
    color: var(--color-accent, #e07730);
  }

  .reviews-filter.active {
    background: var(--color-accent, #e07730);
    border-color: var(--color-accent, #e07730);
    color: #fff;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .review-card {
    background: #fff;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(42, 32, 80, 0.06);
    display: flex;
    flex-direction: column;
  }

  .review-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .review-card__stars {
    display: flex;
    gap: 2px;
  }

  .star {
    color: #ddd;
    font-size: 1.1rem;
  }

  .star--filled {
    color: #f5a623;
  }

  .review-card__date {
    font-size: 0.8rem;
    color: var(--color-text-body, #5a5570);
  }

  .review-card__title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text, #2a2050);
    margin-bottom: 0.75rem;
  }

  .review-card__body {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-body, #5a5570);
    flex-grow: 1;
    margin-bottom: 1rem;
  }

  .review-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    border-top: 1px solid var(--color-border, #d8d4e0);
    padding-top: 0.75rem;
  }

  .review-card__author {
    font-weight: 600;
    color: var(--color-accent, #e07730);
    font-size: 0.9rem;
  }

  .review-card__badges {
    display: flex;
    gap: 0.4rem;
  }

  .review-card__badge {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-weight: 500;
  }

  .review-card__badge--location {
    background: var(--color-bg-lavender, #f4f2fa);
    color: var(--color-primary, #3b3160);
  }

  .review-card__badge--rating {
    background: var(--color-bg-warm, #f9f7f3);
    color: var(--color-text-body, #5a5570);
  }

  .reviews-cta {
    text-align: center;
    padding: 2rem 0;
  }

  .reviews-cta h2 {
    margin-bottom: 1.5rem;
  }

  .review-card--pending {
    border: 2px dashed var(--color-accent, #e07730);
    position: relative;
  }

  .review-card__pending-badge {
    position: absolute;
    top: -0.6rem;
    right: 1rem;
    background: var(--color-accent, #e07730);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  @media (max-width: 480px) {
    .reviews-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
