---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Home', url: 'https://airdamien.com/' },
  { name: 'Reviews', url: 'https://airdamien.com/reviews/' },
  { name: 'Submit Review', url: 'https://airdamien.com/add-site-review/' }
];
---

<BaseLayout
  title="Submit Site Review - Paraglide Mexico | Paraglide Utah"
  description="Submit a fair and honest review of your paragliding session with Damien Mitchell and Air Damien."
  canonicalUrl="https://airdamien.com/add-site-review/"
>
  <div class="page-header">
    <div class="container">
      <h1>Submit Site Review</h1>
    </div>
  </div>

  <Breadcrumbs items={breadcrumbs} />

  <section class="section">
    <div class="container content-narrow">
      <p>We value your honest feedback. Submit a fair and honest review of your paragliding experience with Damien Mitchell and Air Damien.</p>

      <form
        name="site-review"
        method="POST"
        action="/success/?form=site-review"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        class="review-form"
      >
        <input type="hidden" name="form-name" value="site-review" />
        <p class="hidden" aria-hidden="true">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="form-group">
          <label for="reviewer-name">Your Name <span class="required">*</span></label>
          <input type="text" id="reviewer-name" name="name" required />
        </div>

        <div class="form-group">
          <label for="review-rating">Overall Rating <span class="required">*</span></label>
          <select id="review-rating" name="rating" required>
            <option value="">Select a rating</option>
            <option value="5">5 Stars - Excellent</option>
            <option value="4">4 Stars - Very Good</option>
            <option value="3">3 Stars - Good</option>
            <option value="2">2 Stars - Fair</option>
            <option value="1">1 Star - Poor</option>
          </select>
        </div>

        <div class="form-group">
          <label for="review-title">Review Title <span class="required">*</span></label>
          <input type="text" id="review-title" name="title" required placeholder="Summarize your experience" />
        </div>

        <div class="form-group">
          <label for="review-body">Your Review <span class="required">*</span></label>
          <textarea id="review-body" name="review" rows="6" required placeholder="Tell us about your experience flying with Air Damien"></textarea>
        </div>

        <button type="submit" class="btn btn--primary">Submit Review</button>
      </form>

      <div class="review-form__success hidden" id="review-success">
        <h2>Thank you for your review.</h2>
        <p>Your feedback helps other pilots make informed decisions. We appreciate you taking the time to share your experience.</p>
        <a href="/reviews/" class="btn btn--secondary">View All Reviews</a>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Form submits natively to Netlify -->

<style>
  .content-narrow {
    max-width: 650px;
    margin: 0 auto;
  }

  .content-narrow > p {
    text-align: center;
    margin-bottom: 2rem;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  .hidden {
    display: none;
  }

  .review-form .form-group {
    margin-bottom: 1.25rem;
  }

  .review-form label {
    display: block;
    margin-bottom: 0.375rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .required {
    color: var(--color-accent);
  }

  .review-form input,
  .review-form select,
  .review-form textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.2s;
  }

  .review-form input:focus,
  .review-form select:focus,
  .review-form textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(74, 65, 104, 0.1);
  }

  .review-form .btn {
    width: 100%;
  }

  .review-form__success {
    text-align: center;
    padding: 3rem 1.5rem;
    background: var(--color-bg-off);
    border-radius: 12px;
  }

  .review-form__success h2 {
    color: var(--color-success);
    margin-bottom: 1rem;
  }

  .review-form__success p {
    margin-bottom: 1.5rem;
    color: var(--color-text-light);
  }
</style>
