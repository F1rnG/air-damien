---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Home', url: 'https://airdamien.com/' },
  { name: 'Reviews', url: 'https://airdamien.com/reviews/' },
  { name: 'Write a Review', url: 'https://airdamien.com/add-site-review/' }
];
---

<BaseLayout
  title="Submit Site Review - Paraglide Mexico | Paraglide Utah"
  description="Submit a fair and honest review of your paragliding session with Damien Mitchell and Air Damien."
  canonicalUrl="https://airdamien.com/add-site-review/"
>
  <div class="page-header">
    <div class="container">
      <h1>Write a Review</h1>
    </div>
  </div>

  <Breadcrumbs items={breadcrumbs} />

  <section class="section">
    <div class="container content-narrow">
      <p class="review-intro">Share your experience flying with Damien and Air Damien. Your review helps other pilots decide if this trip is right for them.</p>

      <form
        name="site-review"
        method="POST"
        action="/success/?form=site-review"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        class="review-form"
      >
        <input type="hidden" name="form-name" value="site-review" />
        <p class="sr-only" aria-hidden="true">
          <label>Do not fill this out: <input name="bot-field" /></label>
        </p>

        <!-- Name -->
        <div class="form-group">
          <label for="reviewer-name">Your Name <span class="required">*</span></label>
          <input type="text" id="reviewer-name" name="name" required />
        </div>

        <!-- Location -->
        <div class="form-group">
          <label for="review-location">Where did you fly with Damien? <span class="required">*</span></label>
          <select id="review-location" name="location" required>
            <option value="">Select a destination</option>
            <option value="Valle de Bravo, Mexico">Valle de Bravo, Mexico</option>
            <option value="Roldanillo, Colombia">Roldanillo, Colombia</option>
            <option value="Governador Valadares, Brazil">Governador Valadares, Brazil</option>
            <option value="Dolomites, Italy">Dolomites, Italy</option>
            <option value="Utah">Utah</option>
          </select>
        </div>

        <!-- Star Rating -->
        <div class="form-group">
          <label>Your Rating <span class="required">*</span></label>
          <div class="star-selector" id="star-selector">
            <input type="hidden" name="rating" id="rating-value" required value="" />
            <span class="star-selector__star" data-value="1">&#9733;</span>
            <span class="star-selector__star" data-value="2">&#9733;</span>
            <span class="star-selector__star" data-value="3">&#9733;</span>
            <span class="star-selector__star" data-value="4">&#9733;</span>
            <span class="star-selector__star" data-value="5">&#9733;</span>
            <span class="star-selector__label" id="star-label"></span>
          </div>
        </div>

        <!-- Title -->
        <div class="form-group">
          <label for="review-title">Review Title <span class="required">*</span></label>
          <input type="text" id="review-title" name="title" required placeholder="Summarize your experience in a few words" />
        </div>

        <!-- Review Body -->
        <div class="form-group">
          <label for="review-body">Your Review <span class="required">*</span></label>
          <textarea id="review-body" name="review" rows="6" required minlength="50" placeholder="Tell us about your experience flying with Air Damien. What did you learn? What was the highlight?"></textarea>
          <span class="char-count" id="char-count">0 characters (minimum 50)</span>
        </div>

        <!-- Pilot Rating (optional) -->
        <div class="form-group">
          <label for="pilot-rating">Your Pilot Rating (optional)</label>
          <select id="pilot-rating" name="pilot-rating">
            <option value="">Prefer not to say</option>
            <option value="P1">P1 (Student)</option>
            <option value="P2">P2 (Novice)</option>
            <option value="P3">P3 (Intermediate)</option>
            <option value="P4">P4 (Advanced)</option>
            <option value="P5">P5 (Master)</option>
            <option value="Tandem Passenger">Tandem Passenger</option>
          </select>
        </div>

        <!-- When -->
        <div class="form-group">
          <label for="fly-date">When did you fly? (optional)</label>
          <input type="month" id="fly-date" name="fly-date" />
        </div>

        <button type="submit" class="btn btn--primary">Submit Review</button>
      </form>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Star selector
  const stars = document.querySelectorAll('.star-selector__star');
  const ratingInput = document.getElementById('rating-value');
  const starLabel = document.getElementById('star-label');
  const labels = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];
  let selected = 0;

  stars.forEach(star => {
    star.addEventListener('mouseenter', () => {
      const val = parseInt(star.getAttribute('data-value'));
      highlightStars(val);
      starLabel.textContent = labels[val];
    });

    star.addEventListener('click', () => {
      selected = parseInt(star.getAttribute('data-value'));
      ratingInput.value = selected;
      highlightStars(selected);
      starLabel.textContent = labels[selected];
    });
  });

  document.getElementById('star-selector').addEventListener('mouseleave', () => {
    highlightStars(selected);
    starLabel.textContent = selected ? labels[selected] : '';
  });

  function highlightStars(count) {
    stars.forEach(s => {
      const val = parseInt(s.getAttribute('data-value'));
      s.classList.toggle('active', val <= count);
    });
  }

  // Character count
  const textarea = document.getElementById('review-body');
  const charCount = document.getElementById('char-count');
  textarea.addEventListener('input', () => {
    const len = textarea.value.length;
    charCount.textContent = len + ' characters' + (len < 50 ? ' (minimum 50)' : '');
    charCount.style.color = len >= 50 ? '#2d7a4f' : '#5a5570';
  });

  // Form submit: send to Netlify AND save to localStorage
  const form = document.querySelector('.review-form');
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    const formData = new FormData(form);

    // Build review object for localStorage
    const review = {
      name: formData.get('name'),
      location: formData.get('location'),
      rating: parseInt(formData.get('rating')),
      title: formData.get('title'),
      body: formData.get('review'),
      pilotRating: formData.get('pilot-rating') || '',
      date: new Date().toISOString().split('T')[0],
      pending: true
    };

    // Save to localStorage
    const pending = JSON.parse(localStorage.getItem('pendingReviews') || '[]');
    pending.push(review);
    localStorage.setItem('pendingReviews', JSON.stringify(pending));

    // Submit to Netlify
    fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(formData).toString()
    }).then(() => {
      window.location.href = '/success/?form=site-review';
    }).catch(() => {
      // Still redirect even if Netlify fails - review is saved locally
      window.location.href = '/success/?form=site-review';
    });
  });
</script>

<style>
  .content-narrow {
    max-width: 600px;
    margin: 0 auto;
  }

  .review-intro {
    text-align: center;
    margin-bottom: 2rem;
    color: var(--color-text-body, #5a5570);
    line-height: 1.7;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.4rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text, #2a2050);
  }

  .required {
    color: var(--color-accent, #e07730);
  }

  .review-form input,
  .review-form select,
  .review-form textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1.5px solid var(--color-border, #d8d4e0);
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
    color: var(--color-text, #2a2050);
    background: #fff;
    transition: border-color 150ms ease;
  }

  .review-form input:focus,
  .review-form select:focus,
  .review-form textarea:focus {
    outline: none;
    border-color: var(--color-primary, #3b3160);
    box-shadow: 0 0 0 3px rgba(59, 49, 96, 0.1);
  }

  /* Star selector */
  .star-selector {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .star-selector__star {
    font-size: 2rem;
    color: #ddd;
    cursor: pointer;
    transition: color 100ms ease, transform 100ms ease;
    user-select: none;
    line-height: 1;
  }

  .star-selector__star:hover {
    transform: scale(1.15);
  }

  .star-selector__star.active {
    color: #f5a623;
  }

  .star-selector__label {
    margin-left: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-text-body, #5a5570);
    font-weight: 500;
  }

  /* Char count */
  .char-count {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.8rem;
    color: var(--color-text-body, #5a5570);
  }

  .review-form .btn {
    width: 100%;
    margin-top: 0.5rem;
  }
</style>
