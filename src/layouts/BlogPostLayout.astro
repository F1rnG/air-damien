---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

interface RelatedPost {
  title: string;
  url: string;
  description: string;
  date: string;
  readingTime: string;
}

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  datePublished: string;
  dateModified?: string;
  readingTime: string;
  wordCount: number;
  featuredImage?: string;
  featuredImageAlt?: string;
  relatedPosts?: RelatedPost[];
}

const {
  title,
  description,
  canonicalUrl,
  datePublished,
  dateModified,
  readingTime,
  wordCount,
  featuredImage,
  featuredImageAlt,
  relatedPosts = []
} = Astro.props;

const author = {
  name: 'Damien Mitchell',
  title: 'USHPA Advanced Instructor',
  bio: 'Damien Mitchell is a USHPA Advanced Instructor with over 25 years of experience and 10,000+ flights. He teaches paragliding at El Penon in Valle de Bravo, Mexico and at the Point of the Mountain in Draper, Utah.',
  image: '/images/team/damien-mitchell.jpg',
  url: 'https://airdamien.com/about-us/'
};

const breadcrumbs = [
  { name: 'Home', url: 'https://airdamien.com/' },
  { name: 'Blog', url: 'https://airdamien.com/blog/' },
  { name: title, url: canonicalUrl }
];

const blogPostSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": datePublished,
  "dateModified": dateModified || datePublished,
  "wordCount": wordCount,
  "author": {
    "@type": "Person",
    "name": author.name,
    "url": author.url,
    "jobTitle": author.title
  },
  "publisher": {
    "@type": "Organization",
    "name": "Air Damien",
    "url": "https://airdamien.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://airdamien.com/images/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  },
  "image": featuredImage ? `https://airdamien.com${featuredImage}` : "https://airdamien.com/images/logo.png"
};

const formattedDate = new Date(datePublished).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
>
  <SchemaMarkup schema={blogPostSchema} />

  <section class="post-hero">
    {featuredImage ? (
      <img class="post-hero__bg" src={featuredImage} alt={featuredImageAlt || title} width="1920" height="800" loading="eager" />
    ) : (
      <div class="post-hero__bg post-hero__bg--fallback"></div>
    )}
    <div class="post-hero__overlay"></div>
    <div class="post-hero__content">
      <h1>{title}</h1>
    </div>
  </section>

  <Breadcrumbs items={breadcrumbs} />

  <article class="blog-post section">
    <div class="container content-narrow">
      <div class="author-card">
        <img src="/images/damion.jpg" alt="Damien Mitchell" width="56" height="56" class="author-card__avatar" />
        <div class="author-card__info">
          <a href="/about-us/" class="author-card__name">{author.name}</a>
          <span class="author-card__title">USHPA Advanced Instructor</span>
          <span class="author-card__meta">Published {formattedDate} · {readingTime}</span>
        </div>
      </div>

      <div class="blog-post__content">
        <p class="blog-post__lead">{description}</p>
        <slot />
      </div>

      <aside class="blog-post__author-box">
        <div class="blog-post__author-box-avatar">
          <img src="/images/damion.jpg" alt="Damien Mitchell" width="64" height="64" />
        </div>
        <div class="blog-post__author-box-info">
          <h3>About the Author</h3>
          <p class="blog-post__author-box-name"><a href="/about-us/" class="author-link">{author.name}</a></p>
          <p>{author.bio}</p>
          <a href="/about-us/">Learn more about Damien</a>
        </div>
      </aside>

      <RelatedPosts posts={relatedPosts} />
    </div>
  </article>
</BaseLayout>

<style>
  .post-hero {
    position: relative;
    min-height: 45vh;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
  }

  .post-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .post-hero__bg--fallback {
    background: linear-gradient(135deg, var(--color-primary-dark, #2a2050) 0%, var(--color-primary, #3b3160) 100%);
  }

  .post-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(42, 32, 80, 0.1) 0%,
      rgba(42, 32, 80, 0.3) 40%,
      rgba(42, 32, 80, 0.65) 70%,
      rgba(42, 32, 80, 0.85) 100%
    );
    z-index: 1;
  }

  .post-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 2rem 1.5rem 2.5rem;
    max-width: 800px;
  }

  .post-hero__content h1 {
    color: #fff;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    line-height: 1.25;
  }

  .content-narrow {
    max-width: 750px;
    margin: 0 auto;
  }

  .author-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--color-bg-warm, #f9f7f3);
    border-left: 4px solid var(--color-accent, #e07730);
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .author-card__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-accent, #e07730);
    flex-shrink: 0;
  }

  .author-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .author-card__name {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text, #2a2050);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .author-card__name:hover {
    color: var(--color-accent, #e07730);
  }

  .author-card__title {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-accent, #e07730);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .author-card__meta {
    font-size: 0.8rem;
    color: var(--color-text-body, #5a5570);
  }

  .blog-post__author-box-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .blog-post__author-box-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-post__lead {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-text);
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .blog-post__content {
    line-height: 1.8;
    margin-bottom: 3rem;
  }

  .blog-post__content h2 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-post__content h3 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-post__content p {
    margin-bottom: 1.25rem;
  }

  .blog-post__content ul,
  .blog-post__content ol {
    margin: 1rem 0 1.5rem 1.5rem;
    line-height: 1.8;
  }

  .blog-post__content a {
    color: var(--color-accent);
  }

  .blog-post__author-box {
    display: flex;
    gap: 1.25rem;
    padding: 2rem;
    background: var(--color-bg-off);
    border-radius: 12px;
    margin-top: 3rem;
  }

  .blog-post__author-box-avatar {
    width: 64px;
    height: 64px;
    font-size: 1.25rem;
  }

  .blog-post__author-box-info h3 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-light);
    margin-bottom: 0.25rem;
  }

  .blog-post__author-box-name {
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .blog-post__author-box-info p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
  }

  .blog-post__author-box-info a {
    color: var(--color-accent);
    font-size: 0.9rem;
    font-weight: 600;
  }

  @media (max-width: 480px) {
    .blog-post__author-box {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
