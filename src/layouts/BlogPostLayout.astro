---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

interface RelatedPost {
  title: string;
  url: string;
  description: string;
  date: string;
  readingTime: string;
}

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  datePublished: string;
  dateModified?: string;
  readingTime: string;
  wordCount: number;
  featuredImage?: string;
  featuredImageAlt?: string;
  relatedPosts?: RelatedPost[];
}

const {
  title,
  description,
  canonicalUrl,
  datePublished,
  dateModified,
  readingTime,
  wordCount,
  featuredImage,
  featuredImageAlt,
  relatedPosts = []
} = Astro.props;

const author = {
  name: 'Damien Mitchell',
  title: 'USHPA Advanced Instructor',
  bio: 'Damien Mitchell is a USHPA Advanced Instructor with over 25 years of experience and 10,000+ flights. He teaches paragliding at El Penon in Valle de Bravo, Mexico and at the Point of the Mountain in Draper, Utah.',
  image: '/images/team/damien-mitchell.jpg',
  url: 'https://airdamien.com/about-us/'
};

const breadcrumbs = [
  { name: 'Home', url: 'https://airdamien.com/' },
  { name: 'Blog', url: 'https://airdamien.com/blog/' },
  { name: title, url: canonicalUrl }
];

const blogPostSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": datePublished,
  "dateModified": dateModified || datePublished,
  "wordCount": wordCount,
  "author": {
    "@type": "Person",
    "name": author.name,
    "url": author.url,
    "jobTitle": author.title
  },
  "publisher": {
    "@type": "Organization",
    "name": "Air Damien",
    "url": "https://airdamien.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://airdamien.com/images/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  },
  "image": "https://airdamien.com/images/blog/placeholder.jpg"
};

const formattedDate = new Date(datePublished).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
>
  <SchemaMarkup schema={blogPostSchema} />

  <div class="page-header">
    <div class="container">
      <h1>{title}</h1>
    </div>
  </div>

  <Breadcrumbs items={breadcrumbs} />

  <article class="blog-post section">
    <div class="container content-narrow">
      <div class="blog-post__byline">
        <div class="blog-post__author-avatar">
          <img src="/images/damion.jpg" alt="Damien Mitchell" width="48" height="48" />
        </div>
        <div class="blog-post__author-info">
          <span class="blog-post__author-name">By <a href="/about-us/" class="author-link">{author.name}</a>, {author.title}</span>
          <div class="blog-post__meta">
            <time datetime={datePublished}>{formattedDate}</time>
            <span class="blog-post__sep">|</span>
            <span>{readingTime}</span>
          </div>
        </div>
      </div>

      <div class="blog-post__featured-image">
        {featuredImage ? (
          <img src={featuredImage} alt={featuredImageAlt || title} width="750" height="420" loading="eager" />
        ) : (
          <span>Featured Image: {title}</span>
        )}
      </div>

      <div class="blog-post__content">
        <p class="blog-post__lead">{description}</p>
        <slot />
      </div>

      <aside class="blog-post__author-box">
        <div class="blog-post__author-box-avatar">
          <img src="/images/damion.jpg" alt="Damien Mitchell" width="64" height="64" />
        </div>
        <div class="blog-post__author-box-info">
          <h3>About the Author</h3>
          <p class="blog-post__author-box-name"><a href="/about-us/" class="author-link">{author.name}</a></p>
          <p>{author.bio}</p>
          <a href="/about-us/">Learn more about Damien</a>
        </div>
      </aside>

      <RelatedPosts posts={relatedPosts} />
    </div>
  </article>
</BaseLayout>

<style>
  .content-narrow {
    max-width: 750px;
    margin: 0 auto;
  }

  .blog-post__byline {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .blog-post__author-avatar,
  .blog-post__author-box-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    font-weight: 700;
    flex-shrink: 0;
  }

  .blog-post__author-avatar img,
  .blog-post__author-box-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .author-link {
    color: var(--color-primary, #3b3160);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .author-link:hover {
    color: var(--color-accent, #e07730);
    text-decoration: underline;
  }

  .blog-post__author-name {
    font-weight: 600;
    color: var(--color-primary);
    display: block;
    margin-bottom: 0.125rem;
  }

  .blog-post__meta {
    font-size: 0.85rem;
    color: var(--color-text-light);
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .blog-post__sep {
    opacity: 0.4;
  }

  .blog-post__featured-image {
    aspect-ratio: 16 / 9;
    background: var(--color-bg-lavender, #f4f2fa);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    overflow: hidden;
  }

  .blog-post__featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-post__featured-image span {
    color: #fff;
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .blog-post__lead {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-text);
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .blog-post__content {
    line-height: 1.8;
    margin-bottom: 3rem;
  }

  .blog-post__content h2 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-post__content h3 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-post__content p {
    margin-bottom: 1.25rem;
  }

  .blog-post__content ul,
  .blog-post__content ol {
    margin: 1rem 0 1.5rem 1.5rem;
    line-height: 1.8;
  }

  .blog-post__content a {
    color: var(--color-accent);
  }

  .blog-post__author-box {
    display: flex;
    gap: 1.25rem;
    padding: 2rem;
    background: var(--color-bg-off);
    border-radius: 12px;
    margin-top: 3rem;
  }

  .blog-post__author-box-avatar {
    width: 64px;
    height: 64px;
    font-size: 1.25rem;
  }

  .blog-post__author-box-info h3 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-light);
    margin-bottom: 0.25rem;
  }

  .blog-post__author-box-name {
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .blog-post__author-box-info p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
  }

  .blog-post__author-box-info a {
    color: var(--color-accent);
    font-size: 0.9rem;
    font-weight: 600;
  }

  @media (max-width: 480px) {
    .blog-post__author-box {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
