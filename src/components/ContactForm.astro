---
interface Props {
  formName?: string;
  showPhone?: boolean;
  showSubject?: boolean;
  messageLabel?: string;
}

const {
  formName = 'contact',
  showPhone = true,
  showSubject = true,
  messageLabel = 'Message',
} = Astro.props;
---

<form
  class="form"
  name={formName}
  method="POST"
  data-netlify="true"
  data-netlify-honeypot="bot-field"
>
  <input type="hidden" name="form-name" value={formName} />
  <p class="form__hidden" aria-hidden="true">
    <label>
      Do not fill this out: <input name="bot-field" />
    </label>
  </p>

  <div class="form__group">
    <label class="form__label" for={`${formName}-name`}>Name *</label>
    <input
      class="form__input"
      type="text"
      id={`${formName}-name`}
      name="name"
      required
    />
  </div>

  <div class="form__group">
    <label class="form__label" for={`${formName}-email`}>Email *</label>
    <input
      class="form__input"
      type="email"
      id={`${formName}-email`}
      name="email"
      required
    />
  </div>

  {showPhone && (
    <div class="form__group">
      <label class="form__label" for={`${formName}-phone`}>Phone</label>
      <input
        class="form__input"
        type="tel"
        id={`${formName}-phone`}
        name="phone"
      />
    </div>
  )}

  {showSubject && (
    <div class="form__group">
      <label class="form__label" for={`${formName}-subject`}>Subject *</label>
      <input
        class="form__input"
        type="text"
        id={`${formName}-subject`}
        name="subject"
        required
      />
    </div>
  )}

  <div class="form__group">
    <label class="form__label" for={`${formName}-message`}>{messageLabel} *</label>
    <textarea
      class="form__textarea"
      id={`${formName}-message`}
      name="message"
      required
    ></textarea>
  </div>

  <button type="submit" class="btn btn--primary">Send Message</button>
</form>

<style>
  .form__hidden {
    display: none;
  }
</style>
