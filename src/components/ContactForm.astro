---
interface Props {
  formName?: string;
  showPhone?: boolean;
  messagePlaceholder?: string;
  buttonText?: string;
}

const {
  formName = 'contact',
  showPhone = true,
  messagePlaceholder = '',
  buttonText = 'Send Message',
} = Astro.props;
---

<form
  class="form"
  name={formName}
  method="POST"
  action={`/success/?form=${formName}`}
  data-netlify="true"
  data-netlify-honeypot="bot-field"
>
  <input type="hidden" name="form-name" value={formName} />
  <p class="form__hidden" aria-hidden="true">
    <label>
      Do not fill this out: <input name="bot-field" />
    </label>
  </p>

  <div class="form__group">
    <label class="form__label" for={`${formName}-name`}>Name *</label>
    <input
      class="form__input"
      type="text"
      id={`${formName}-name`}
      name="name"
      required
    />
  </div>

  <div class="form__group">
    <label class="form__label" for={`${formName}-email`}>Email *</label>
    <input
      class="form__input"
      type="email"
      id={`${formName}-email`}
      name="email"
      required
    />
  </div>

  {showPhone && (
    <div class="form__group">
      <label class="form__label" for={`${formName}-phone`}>Phone</label>
      <input
        class="form__input"
        type="tel"
        id={`${formName}-phone`}
        name="phone"
      />
    </div>
  )}

  <div class="form__group">
    <label class="form__label" for={`${formName}-message`}>Message *</label>
    <textarea
      class="form__textarea"
      id={`${formName}-message`}
      name="message"
      required
      placeholder={messagePlaceholder}
    ></textarea>
  </div>

  <button type="submit" class="btn btn--primary">{buttonText}</button>
</form>

<div class="form-trust">
  <p>Or call Damien directly: <a href="tel:+18012444791">801-244-4791</a></p>
  <a href="/reviews/" class="form-trust__badge">
    <span class="form-trust__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
    <span>5.0 / 33 reviews</span>
  </a>
</div>

<style>
  .form__hidden {
    display: none;
  }

  .form-trust {
    text-align: center;
    margin-top: 1.25rem;
    font-size: 0.9rem;
    color: var(--color-text-light, #666);
  }

  .form-trust a {
    color: var(--color-accent, #e8732a);
    font-weight: 600;
  }

  .form-trust__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    text-decoration: none;
    font-size: 0.85rem;
  }

  .form-trust__stars {
    color: #f5a623;
    letter-spacing: 1px;
  }
</style>
