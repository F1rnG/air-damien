---
interface Props {
  name: string;
  role: string;
  bio: string;
  placeholder?: string;
  image?: string;
  imageAlt?: string;
}

const { name, role, bio, placeholder = 'Team member photo', image, imageAlt } = Astro.props;
---

<div class="card">
  <div class="card__image">
    {image ? <img src={image} alt={imageAlt || `${name} photo`} width="800" height="600" loading="lazy" /> : placeholder}
  </div>
  <div class="card__body">
    <h3>{name}</h3>
    <p class="team-card__role">{role}</p>
    <p>{bio}</p>
  </div>
</div>

<style>
  .team-card__role {
    color: var(--color-sunset);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
</style>
