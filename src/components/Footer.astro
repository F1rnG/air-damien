  }

  .footer-col h4 {
    color: var(--color-text-on-dark, #fff);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
    font-weight: 600;
