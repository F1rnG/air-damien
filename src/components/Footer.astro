<style>
  .footer {
    background: var(--color-charcoal);
    color: var(--color-cream);
  }

  .footer__main {
    padding: 4rem 1.5rem 2rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 640px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .footer__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .footer__col h4 {
    color: var(--color-sunset);
    font-size: 1rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .footer__col p,
  .footer__col li {
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(248, 246, 242, 0.8);
  }

  .footer__col a {
    color: rgba(248, 246, 242, 0.8);
    font-size: 0.9rem;
  }

  .footer__col a:hover {
    color: var(--color-sunset);
  }

  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer__coords {
    font-size: 0.8rem;
    opacity: 0.6;
    margin-top: 0.5rem;
  }

  .footer__posts {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 2rem;
    margin-bottom: 2rem;
  }

  .footer__posts h4 {
    color: var(--color-sunset);
    font-size: 1rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .footer__posts ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__posts a {
    color: rgba(248, 246, 242, 0.8);
    font-size: 0.9rem;
  }

  .footer__posts a:hover {
    color: var(--color-sunset);
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer__social a {
    color: rgba(248, 246, 242, 0.7);
    transition: color 0.2s, transform 0.2s;
  }

  .footer__social a:hover {
    color: var(--color-sunset);
    transform: translateY(-2px);
  }

  .footer__bottom {
    background: rgba(0, 0, 0, 0.3);
    padding: 1rem 1.5rem;
    text-align: center;
  }

  .footer__bottom p {
    font-size: 0.85rem;
    opacity: 0.6;
    margin: 0;
  }
</style>
