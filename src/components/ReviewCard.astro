---
interface Props {
  author: string;
  date: string;
  text: string;
  rating?: number;
}

const { author, date, text, rating = 5 } = Astro.props;
const stars = '\u2605'.repeat(rating);
---

<div class="review-card">
  <div class="review-card__header">
    <span class="stars">{stars}</span>
    <span class="review-card__date">{date}</span>
  </div>
  <p class="review-card__text">{text}</p>
  <p class="review-card__author">{author}</p>
</div>

<style>
  .review-card {
    background: var(--color-white);
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }

  .review-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .review-card__date {
    font-size: 0.85rem;
    color: var(--color-gray-light);
  }

  .review-card__text {
    font-style: italic;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .review-card__author {
    font-weight: 700;
    color: var(--color-sky);
    margin: 0;
  }
</style>
